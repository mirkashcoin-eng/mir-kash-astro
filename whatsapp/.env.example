# Mir Kash WhatsApp — function secrets.
# Set these with the Supabase CLI (NOT committed):
#   supabase secrets set META_ACCESS_TOKEN=xxxx
#   supabase secrets set META_API_VERSION=v21.0
#
# Note: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically into
# Edge Functions by Supabase — you do NOT set those yourself.

# Permanent Meta WhatsApp token (System User token; never the 24h temporary one).
META_ACCESS_TOKEN=

# Graph API version (optional; defaults to v21.0 in code).
META_API_VERSION=v21.0
