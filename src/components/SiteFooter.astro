---
import CountrySelector from './CountrySelector.astro';
---
<footer class="site-footer">

  <div class="footer-info">
    <div class="fi-mark" aria-hidden="true">
      <img src="/mir-kash-monogram.png" alt="Mir Kash" />
    </div>

    <h3 class="fi-heading">The Mir Kash <em>promise</em></h3>

    <div class="fi-cols">
      <div class="fi-col">
        <p class="fi-label">Note from Founder</p>
        <p class="fi-val">Made slowly.<br />Worn forever. Hurts nothing.</p>
      </div>
      <div class="fi-col">
        <p class="fi-label">Order it. Try it.</p>
        <p class="fi-val">14 days to decide.<br />No question returns.</p>
      </div>
      <div class="fi-col">
        <p class="fi-label">Built to Last</p>
        <p class="fi-val">3-year warranty</p>
      </div>
    </div>

    <form class="fi-news" onsubmit="event.preventDefault();">
      <span class="fi-news__icon" aria-hidden="true">
        <svg width="22" height="16" viewBox="0 0 24 18" fill="none" stroke="currentColor" stroke-width="1.4">
          <rect x="1" y="1" width="22" height="16" rx="0" />
          <polyline points="1 2 12 11 23 2" />
        </svg>
      </span>
      <input class="fi-news__input" type="email" placeholder="Letters from the atelier — once a season, never more" required />
      <button class="fi-news__submit" type="submit">Subscribe</button>
    </form>
  </div>

  <div class="footer-acc">
    <details class="fa-col" open>
      <summary>
        <span>Mir Kash</span>
        <svg class="fa-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <ul>
        <li><a href="#">Blog</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Materials</a></li>
        <li><a href="#">Work with Us</a></li>
        <li><a href="#">FAQ</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </details>
    <details class="fa-col" open>
      <summary>
        <span>Shop</span>
        <svg class="fa-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <ul>
        <li><a href="#">Book a home demo</a></li>
        <li><a href="#">Shipping &amp; Returns</a></li>
        <li><a href="#">Track Order</a></li>
        <li><a href="#">Bulk Gifting</a></li>
      </ul>
    </details>
    <details class="fa-col" open>
      <summary>
        <span>Legal</span>
        <svg class="fa-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <ul>
        <li><a href="#">Terms</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Sitemap</a></li>
        <li><a href="#">Accessibility</a></li>
      </ul>
    </details>
    <details class="fa-col" open>
      <summary>
        <span>Social</span>
        <svg class="fa-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <ul>
        <li><a href="https://www.instagram.com/mirkashco/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
        <li><a href="https://www.facebook.com/people/MIR-KASH/61553891201492/?mibextid=LQQJ4d" target="_blank" rel="noopener noreferrer">Facebook</a></li>
        <li><a href="https://in.pinterest.com/mirkashco/" target="_blank" rel="noopener noreferrer">Pinterest</a></li>
        <li><a href="https://www.linkedin.com/company/mirkash/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
      </ul>
    </details>
    <details class="fa-col" open>
      <summary>
        <span>Locations</span>
        <svg class="fa-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <ul>
        <li>
          <strong class="fa-loc__city">Hong Kong</strong>
          <span class="fa-loc__addr">Guardforce Centre, 03 Hok Yuen Street, Hung Hom, Hong Kong</span>
        </li>
        <li>
          <strong class="fa-loc__city">India</strong>
          <span class="fa-loc__addr">Jaywant Industrial Estate, Tardeo, Mumbai — 400034</span>
        </li>
        <li>
          <strong class="fa-loc__city">New York, USA</strong>
          <span class="fa-loc__addr">37W, 47th Street, New York, USA 10036</span>
        </li>
      </ul>
    </details>
  </div>

  <div class="footer-bottom">
    <div class="fb-copy">© MIR KASH 2026</div>
    <div class="fb-meta">
      <CountrySelector />
      <a href="#">Language: english <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"></polyline></svg></a>
    </div>
  </div>

</footer>

<script>
  (function () {
    const cols = document.querySelectorAll('.fa-col');
    if (!cols.length) return;
    let syncing = false;
    cols.forEach((d) => {
      d.addEventListener('toggle', () => {
        if (syncing) return;
        syncing = true;
        const target = (d as HTMLDetailsElement).open;
        cols.forEach((o) => {
          if ((o as HTMLDetailsElement).open !== target) (o as HTMLDetailsElement).open = target;
        });
        syncing = false;
      });
    });
  })();
</script>

<style is:global>
  /* Make the footer self-contained: it carries the site theme variables itself,
     so it renders identically on pages (cart/checkout) that override :root. */
  .site-footer {
    --serif: 'Cormorant Garamond', 'Times New Roman', serif;
    --font: 'Jost', -apple-system, 'Helvetica Neue', sans-serif;
    --cherry: #8B1A1A; --depth: #2C1A0E; --paper: #f6f3ee; --cream: #ebe6dd;
    --rule: #e4dfd7; --ink: #141414; --ink-mid: #6e6a64; --ink-soft: #a8a39c;
    --gutter: clamp(20px, 4vw, 56px);
    background: var(--paper); color: var(--depth); font-family: var(--font); text-align: left;
  }
  .site-footer .fi-heading { font-family: var(--serif); font-weight: 300; font-style: normal; font-size: clamp(22px,2.2vw,32px); letter-spacing: 0; text-transform: none; color: var(--depth); margin-top: 12px; }
  .site-footer .fi-heading em { font-style: normal; color: var(--cherry); }
  .site-footer .fi-val { font-family: var(--serif); font-style: normal; font-weight: 300; font-size: clamp(16px,1.3vw,20px); letter-spacing: 0; text-transform: none; color: var(--depth); line-height: 1.35; }
  .site-footer .fi-label { font-size: 10.5px; color: var(--ink-mid); }
  .site-footer .fi-news { border-bottom-color: var(--depth); }
  .site-footer .fi-news__input { font-family: var(--serif); font-style: normal; font-weight: 300; font-size: 16px; letter-spacing: 0; }
  .site-footer .fi-news__input::placeholder { font-family: var(--serif); font-style: normal; color: var(--ink-mid); letter-spacing: 0; text-transform: none; }
  .site-footer .fi-news__submit:hover { color: var(--cherry); opacity: 1; }
  .site-footer .fa-col summary { color: var(--depth); font-weight: 500; }
  .site-footer .fa-col ul li a:hover { color: var(--cherry); opacity: 1; }
  .site-footer .footer-bottom { border-top: 1px solid var(--rule); position: relative; }
  .site-footer .footer-bottom::before { content: ''; position: absolute; top: -1px; left: 50%; transform: translateX(-50%); width: 60px; height: 1px; background: var(--cherry); }
  .site-footer .fb-meta a:hover { color: var(--cherry); }
  @media (max-width: 768px) { .site-footer .fi-heading { font-size: 22px; } }
</style>
