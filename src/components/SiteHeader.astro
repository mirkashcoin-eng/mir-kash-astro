---
import { getCartCount } from '~/lib/cart-session';

const { market, marketConfig } = Astro.locals;
const prefix = marketConfig.urlPrefix;
const homeHref = prefix || '/';
const cartHref = `${prefix}/cart`;
const cartCount = getCartCount(Astro.cookies, market);

const navItems = [
  { word: 'Shop All',  href: `${prefix}/shop` },
  { word: 'Materials', href: `${prefix}/pages/materials` },
  { word: 'Journal',   href: `${homeHref}#journal` },
  { word: 'About',     href: `${prefix}/pages/about` },
];
---
<div class="page-header hdr--solid">
  <header class="site-header site-header--minimal">
    <div class="hdr-wrap">

      <button class="hdr-menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="navDrawer" type="button">
        <span class="hdr-menu-btn__bars" aria-hidden="true">
          <span></span><span></span>
        </span>
        <span class="hdr-menu-btn__label">Menu</span>
      </button>

      <a href={homeHref} class="logo">
        <img src="/mir-kash-logo.webp" alt="Mir Kash" />
      </a>

      <div class="hdr-right">
        <a class="hdr-icon-btn hdr-account" href="/account" aria-label="Account">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"></circle><path d="M4 21c0-4 4-6 8-6s8 2 8 6"></path></svg>
          <span class="hdr-account__dot" aria-hidden="true"></span>
        </a>
        <a class="hdr-icon-btn hdr-bag" href={cartHref} aria-label="Bag">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          <span class="hdr-bag__count">{cartCount}</span>
        </a>
      </div>

    </div>

    <div class="hdr-nav-row">
      <nav class="main-nav">
        {navItems.map((i) => (
          <a href={i.href}>{i.word}</a>
        ))}
      </nav>
    </div>
  </header>
</div>

<script>
  (function () {
    const hdr = document.querySelector('.page-header.hdr--solid');
    if (!hdr) return;
    const threshold = 80;
    function update() {
      if (window.scrollY > threshold) hdr!.classList.add('is-scrolled');
      else hdr!.classList.remove('is-scrolled');
    }
    update();
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>

<script>
  // Keep the bag badge in sync with the live cart. Pages are CDN-cached (and may be
  // restored from the browser's back-forward cache), so refresh on load, on pageshow
  // (covers bfcache back-navigation), and when the tab regains focus.
  (function () {
    const el = document.querySelector('.hdr-bag__count');
    if (!el) return;
    async function refresh() {
      try {
        const store = (window as any).__MARKET__ || 'india';
        const res = await fetch(`/api/cart?store=${store}`, { cache: 'no-store' });
        if (!res.ok) return;
        const cart = await res.json();
        el!.textContent = String(cart.totalQuantity ?? 0);
      } catch {}
    }
    refresh();
    window.addEventListener('pageshow', refresh);
    document.addEventListener('visibilitychange', () => { if (!document.hidden) refresh(); });
  })();
</script>

<script>
  // Reflect the signed-in customer across the whole site (header is CDN-cached, so
  // this runs client-side, like the bag badge). Shows a dot on the account icon and
  // greets them by first name.
  import { firebaseConfigured, getSessionUser } from '~/lib/firebaseClient';
  (async function () {
    const btn = document.querySelector<HTMLAnchorElement>('.hdr-account');
    if (!btn || !firebaseConfigured()) return;
    const user = await getSessionUser();
    if (!user) return;
    const first = (user.displayName || user.email || '').trim().split(/[\s@]/)[0] || 'there';
    btn.classList.add('is-auth');
    btn.setAttribute('aria-label', 'Hi, ' + first);
    btn.setAttribute('title', 'Hi, ' + first);
  })();
</script>

<style>
  .hdr-account { position: relative; }
  .hdr-account__dot {
    position: absolute; top: 6px; right: 6px; width: 7px; height: 7px;
    border-radius: 50%; background: #3D6B4F; box-shadow: 0 0 0 2px #fff;
    opacity: 0; transform: scale(.6); transition: opacity .2s, transform .2s;
  }
  .hdr-account.is-auth .hdr-account__dot { opacity: 1; transform: scale(1); }
</style>
