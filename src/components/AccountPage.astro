---
import { firebaseConfigured } from '~/lib/firebaseClient';
import { STATES } from '~/lib/india-locations';
const ready = firebaseConfigured();
---

<header class="acct-head">
  <a href="/" class="acct-logo" aria-label="Mir Kash"><img src="/mir-kash-logo.webp" alt="Mir Kash" /></a>
  <a href="/cart" class="acct-bag" aria-label="Bag">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
  </a>
</header>

<main class="acct">
  <h1 class="acct__title">My Account</h1>

  {!ready && (
    <p class="acct__note">Accounts aren’t set up yet. Please check back soon.</p>
  )}

  <!-- Signed-out -->
  <section class="acct__signin" id="signedOut" hidden>
    <p class="acct__lede">Sign in to see your orders, request returns, and check out faster.</p>
    <button class="g-btn" id="googleBtn" type="button">
      <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
      Continue with Google
    </button>
  </section>

  <!-- Signed-in -->
  <section id="signedIn" hidden>
    <div class="acct__hero">
      <h2 class="acct__hello" id="hello">Welcome back</h2>
      <div class="acct__sub">
        <span id="who" class="acct__who"></span>
        <button class="acct__signout" id="signoutBtn" type="button">Sign out</button>
      </div>
    </div>

    <h2 class="acct__h2">Saved address</h2>

    <!-- Read-only card (shown when an address is already saved) -->
    <div class="acct__card" id="addrCard" hidden>
      <div class="acct__cardname" id="cardName"></div>
      <div class="acct__cardline" id="cardPhone"></div>
      <div class="acct__cardline" id="cardAddr"></div>
      <button class="acct__edit" id="editBtn" type="button">Edit address</button>
    </div>

    <!-- Editable form (revealed by "Edit", or shown directly when no address yet) -->
    <div class="acct__form" id="addrForm" hidden>
      <p class="acct__note acct__prompt" id="addrPrompt" hidden>Add your delivery address so checkout is one tap.</p>
      <div class="af"><label>Full name</label><input id="p-name" type="text" /></div>
      <div class="af"><label>Phone</label><input id="p-phone" type="tel" /></div>
      <div class="af"><label>Address</label><input id="p-addr1" type="text" /></div>
      <div class="af"><label>Apartment (optional)</label><input id="p-addr2" type="text" /></div>
      <div class="af3">
        <div class="af"><label>State</label>
          <select id="p-state"><option value="">Select state</option>{STATES.map((s) => <option value={s}>{s}</option>)}</select>
        </div>
        <div class="af"><label>City</label>
          <input id="p-city" type="text" list="acctCities" placeholder="Select state first" autocomplete="off" />
          <datalist id="acctCities"></datalist>
        </div>
        <div class="af"><label>PIN</label><input id="p-zip" type="text" maxlength="6" inputmode="numeric" /></div>
      </div>
      <div class="acct__actions">
        <button class="acct__save" id="saveBtn" type="button">Save address</button>
        <button class="acct__cancel" id="cancelBtn" type="button" hidden>Cancel</button>
        <span class="acct__saved" id="savedMsg" hidden>Saved ✓</span>
      </div>
    </div>

    <h2 class="acct__h2">Order history</h2>
    <div id="orders" class="acct__orders"><p class="acct__note" id="ordersLoading">Loading your orders…</p></div>
  </section>
</main>

<script>
  import { getSessionUser, getIdToken, signInWithGoogle, signOut, loadProfile, saveProfile } from '~/lib/firebaseClient';
  import { citiesFor } from '~/lib/india-locations';

  const $ = (id: string) => document.getElementById(id) as HTMLElement;
  const v = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value.trim() ?? '';

  // Fill the city datalist from the chosen state.
  function fillCities(state: string) {
    const dl = $('acctCities'); if (!dl) return;
    dl.innerHTML = citiesFor(state).map((c) => `<option value="${c}"></option>`).join('');
  }

  function inr(amount: string, currency: string) {
    const n = Math.round(Number(amount));
    try { return new Intl.NumberFormat('en-IN', { style: 'currency', currency, maximumFractionDigits: 0 }).format(n); }
    catch { return currency + ' ' + n.toLocaleString('en-IN'); }
  }

  const setVal = (id: string, value?: string | null) => { (document.getElementById(id) as HTMLInputElement).value = value ?? ''; };
  const hasAddress = () => Boolean(v('p-name') || v('p-addr1'));

  // Render the read-only summary card from the current form values.
  function renderCard() {
    $('cardName').textContent = v('p-name') || '—';
    $('cardPhone').textContent = v('p-phone') ? '+91 ' + v('p-phone').replace(/\D/g, '').slice(-10) : '';
    const cityLine = [v('p-city'), v('p-state'), v('p-zip')].filter(Boolean).join(', ');
    $('cardAddr').innerHTML = [v('p-addr1'), v('p-addr2'), cityLine].filter(Boolean).join('<br>');
    $('addrCard').hidden = false;
    $('addrForm').hidden = true;
  }
  function showForm(withPrompt: boolean) {
    $('addrPrompt').hidden = !withPrompt;
    $('cancelBtn').hidden = !hasAddress();
    $('addrCard').hidden = true;
    $('addrForm').hidden = false;
  }

  async function init() {
    const user = await getSessionUser();
    if (!user) { $('signedOut').hidden = false; return; }
    $('signedIn').hidden = false;

    const stateSel = document.getElementById('p-state') as HTMLSelectElement;
    stateSel.addEventListener('change', () => fillCities(stateSel.value));

    // Saved address → fill the form (so Edit has data) then decide card vs form.
    const p = await loadProfile(user.uid);
    if (p) {
      setVal('p-name', p.full_name); setVal('p-phone', p.phone);
      setVal('p-addr1', p.address1); setVal('p-addr2', p.address2);
      stateSel.value = p.province ?? ''; fillCities(stateSel.value);
      setVal('p-city', p.city); setVal('p-zip', p.zip);
    }

    const first = ((p?.full_name || user.email || '').trim().split(/[\s@]/)[0]) || 'there';
    $('hello').textContent = 'Welcome back, ' + first;
    $('who').textContent = 'Signed in as ' + (user.email ?? 'your account');

    if (hasAddress()) renderCard(); else showForm(true);

    $('editBtn').addEventListener('click', () => showForm(false));
    $('cancelBtn').addEventListener('click', () => { if (hasAddress()) renderCard(); });

    $('saveBtn').addEventListener('click', async () => {
      const ok = await saveProfile({
        id: user.uid, full_name: v('p-name'), phone: v('p-phone'), address1: v('p-addr1'),
        address2: v('p-addr2'), city: v('p-city'), province: v('p-state'), zip: v('p-zip'),
        email: user.email ?? null,
      });
      const m = $('savedMsg'); m.hidden = false; m.textContent = ok ? 'Saved ✓' : 'Could not save';
      setTimeout(() => { m.hidden = true; }, 2500);
      if (ok) renderCard();
    });

    loadOrders();
  }

  async function loadOrders() {
    const token = await getIdToken();
    const box = $('orders');
    try {
      const res = await fetch('/api/account/orders', { headers: { Authorization: 'Bearer ' + token } });
      const data = await res.json();
      const orders = data.orders || [];
      if (!orders.length) { box.innerHTML = '<p class="acct__note">No orders yet. Orders you place will appear here — with a one-tap return option.</p>'; return; }
      const STEPS = ['Ordered', 'Shipped', 'Out for delivery', 'Delivered'];
      const renderCard = (o: any) => {
        const fs = String(o.fulfillmentStatus || '').toUpperCase();
        const shipped = fs.includes('FULFILLED') && !fs.includes('UNFULFILLED');
        let action: string;
        if (o.cancelledAt) action = '<span class="ord__cancelled">Cancelled</span>';
        else if (shipped) action = o.returnRequested
          ? '<span class="ord__ret">Return requested</span>'
          : `<button class="ord__retbtn" data-order="${o.id}">Request a return</button>`;
        else action = `<button class="ord__cancelbtn" data-cancel="${o.id}">Cancel order</button>`;

        // Progress stepper — derive the stage from the shipment status (falls back to fulfilled).
        const ship = String(o.shipmentStatus || '').toUpperCase();
        let stage = 0;
        if (ship === 'DELIVERED') stage = 3;
        else if (['OUT_FOR_DELIVERY', 'ATTEMPTED_DELIVERY', 'READY_FOR_PICKUP', 'PICKED_UP'].includes(ship)) stage = 2;
        else if (shipped || o.tracking || ['IN_TRANSIT', 'CONFIRMED', 'LABEL_PRINTED', 'SUBMITTED'].includes(ship)) stage = 1;
        const stepper = o.cancelledAt ? '' : `
          <div class="track">
            ${STEPS.map((s, i) => `<div class="track__step${i <= stage ? ' done' : ''}"><span class="track__dot"></span><span class="track__lbl">${s}</span></div>`).join('')}
          </div>
          ${o.estimatedDeliveryAt ? `<div class="track__eta">Estimated delivery: ${new Date(o.estimatedDeliveryAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}</div>` : ''}
          ${o.tracking && o.tracking.url ? `<a class="track__link" href="${o.tracking.url}" target="_blank" rel="noopener">Track shipment${o.tracking.company ? ' · ' + o.tracking.company : ''}${o.tracking.number ? ' (' + o.tracking.number + ')' : ''}</a>` : ''}`;

        return `
        <div class="ord">
          <div class="ord__top">
            <span class="ord__name">${o.name}</span>
            <span class="ord__total">${inr(o.total.amount, o.total.currencyCode)}</span>
          </div>
          <div class="ord__meta">${new Date(o.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })} · ${o.financialStatus} · ${o.fulfillmentStatus}</div>
          <div class="ord__items">${o.items.map((i: any) => `${i.quantity}× ${i.title}`).join(', ')}</div>
          ${stepper}
          ${action}
        </div>`;
      };

      // Delivered or cancelled orders move to "Past orders"; everything else stays active.
      const isPast = (o: any) => !!o.cancelledAt || String(o.shipmentStatus || '').toUpperCase() === 'DELIVERED';
      const active = orders.filter((o: any) => !isPast(o));
      const past = orders.filter(isPast);
      box.innerHTML =
        (active.length ? active.map(renderCard).join('') : '') +
        (past.length ? `<h3 class="ord-group__title">Past orders</h3>` + past.map(renderCard).join('') : '');
    } catch {
      box.innerHTML = '<p class="acct__note">Could not load orders.</p>';
    }
  }

  document.getElementById('orders')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-order]');
    if (!btn) return;
    const reason = prompt('Reason for return (optional):') ?? '';
    btn.disabled = true; btn.textContent = 'Requesting…';
    const token = await getIdToken();
    try {
      const res = await fetch('/api/account/return-request', {
        method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
        body: JSON.stringify({ orderId: btn.dataset.order, reason }),
      });
      if (!res.ok) throw new Error();
      btn.replaceWith(Object.assign(document.createElement('span'), { className: 'ord__ret', textContent: 'Return requested' }));
    } catch { btn.disabled = false; btn.textContent = 'Request a return'; alert('Could not submit. Try again.'); }
  });

  document.getElementById('orders')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-cancel]');
    if (!btn) return;
    if (!confirm('Cancel this order? This cannot be undone.')) return;
    btn.disabled = true; btn.textContent = 'Cancelling…';
    const token = await getIdToken();
    try {
      const res = await fetch('/api/account/cancel-order', {
        method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
        body: JSON.stringify({ orderId: btn.dataset.cancel }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || '');
      btn.replaceWith(Object.assign(document.createElement('span'), { className: 'ord__cancelled', textContent: 'Cancelled' }));
      if (data.refundPending) alert('Your order has been cancelled. Your refund will be processed shortly.');
    } catch (err: any) {
      btn.disabled = false; btn.textContent = 'Cancel order';
      alert(err?.message || 'Could not cancel this order. Please try again or contact us.');
    }
  });

  $('googleBtn')?.addEventListener('click', async () => {
    try { await signInWithGoogle(); location.reload(); }
    catch (e: any) {
      const code = e?.code || e?.message || 'unknown';
      if (code === 'auth/popup-closed-by-user' || code === 'auth/cancelled-popup-request') return;
      alert('Sign-in failed: ' + code +
        (code === 'auth/operation-not-allowed' ? '\n\nEnable Google in Firebase → Authentication → Sign-in method.' :
         code === 'auth/unauthorized-domain' ? '\n\nAdd this domain in Firebase → Authentication → Settings → Authorized domains.' : ''));
    }
  });
  $('signoutBtn')?.addEventListener('click', async () => { await signOut(); location.reload(); });

  init();
</script>

<style is:global>
  body { font-family: 'Jost', -apple-system, sans-serif; color: #141414; background: #fff; }
  .acct-head { display: flex; align-items: center; justify-content: space-between; max-width: 620px; margin: 0 auto; padding: 20px 22px 18px; border-bottom: 1px solid #e6e6e6; }
  .acct-logo img { height: 19px; display: block; filter: brightness(0); }
  .acct-bag { width: 38px; height: 38px; border: 1px solid #e6e6e6; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1a1a1a; }
  .acct { max-width: 620px; margin: 0 auto; padding: clamp(36px,6vw,72px) 22px 80px; font-family: 'Jost', sans-serif; color: #1a1a1a; }
  .acct__title { font-size: clamp(28px,5vw,40px); font-weight: 400; margin-bottom: 24px; }
  .acct__h2 { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #6b6b6b; margin: 38px 0 16px; font-weight: 500; }
  .acct__note { color: #6b6b6b; font-size: 14px; }
  .acct__lede { color: #6b6b6b; font-size: 15px; margin-bottom: 22px; line-height: 1.6; }
  .g-btn { display: inline-flex; align-items: center; gap: 11px; height: 50px; padding: 0 22px; border: 1px solid #e6e6e6; background: #fff; cursor: pointer; font-size: 14px; font-weight: 500; transition: border-color .2s; }
  .g-btn:hover { border-color: #1a1a1a; }
  .acct__hero { border-bottom: 1px solid #e6e6e6; padding-bottom: 18px; }
  .acct__hello { font-size: clamp(22px,4vw,30px); font-weight: 400; color: #1a1a1a; margin-bottom: 8px; }
  .acct__sub { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .acct__who { font-size: 13px; color: #6b6b6b; }
  .acct__signout { background: none; border: none; cursor: pointer; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: #8B1A1A; flex-shrink: 0; }
  .acct__card { border: 1px solid #e6e6e6; padding: 18px 20px; }
  .acct__cardname { font-size: 14px; font-weight: 600; margin-bottom: 6px; }
  .acct__cardline { font-size: 14px; color: #4a4a4a; line-height: 1.55; }
  .acct__edit { margin-top: 16px; background: none; border: 1px solid #e6e6e6; padding: 8px 16px; cursor: pointer; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; transition: border-color .2s, color .2s; }
  .acct__edit:hover { border-color: #1a1a1a; }
  .acct__prompt { margin-bottom: 4px; }
  .acct__actions { display: flex; align-items: center; gap: 14px; margin-top: 6px; }
  .acct__cancel { background: none; border: none; cursor: pointer; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: #6b6b6b; }
  .acct__cancel:hover { color: #1a1a1a; }
  .acct__form { display: flex; flex-direction: column; gap: 16px; }
  .acct__form[hidden] { display: none; }
  .af { display: flex; flex-direction: column; }
  .af label { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: #6b6b6b; margin-bottom: 7px; font-weight: 500; }
  .af input, .af select { border: none; border-bottom: 1px solid #e6e6e6; padding: 9px 0; font-size: 15px; outline: none; font-family: inherit; background: transparent; color: #1a1a1a; }
  .af input:focus, .af select:focus { border-bottom-color: #1a1a1a; }
  .af select { -webkit-appearance: none; appearance: none; cursor: pointer; background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23a8a39c' stroke-width='1.2'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 2px center; }
  .af3 { display: grid; grid-template-columns: 1fr 1fr 110px; gap: 16px; }
  .acct__save { align-self: flex-start; height: 46px; padding: 0 28px; background: #1a1a1a; color: #fff; border: none; cursor: pointer; font-size: 11px; letter-spacing: .13em; text-transform: uppercase; font-weight: 500; transition: background .2s; margin-top: 6px; }
  .acct__save:hover { background: #8B1A1A; }
  .acct__saved { font-size: 12px; color: #3D6B4F; margin-left: 12px; }
  .acct__orders { display: flex; flex-direction: column; gap: 14px; }
  .ord { border: 1px solid #e6e6e6; padding: 16px 18px; }
  .ord__top { display: flex; justify-content: space-between; align-items: baseline; }
  .ord__name { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; font-weight: 600; }
  .ord__total { font-size: 15px; }
  .ord__meta { font-size: 12px; color: #6b6b6b; margin: 6px 0; text-transform: capitalize; }
  .ord__items { font-size: 13px; color: #1a1a1a; }
  .ord__retbtn, .ord__cancelbtn { margin-top: 12px; background: none; border: 1px solid #e6e6e6; padding: 8px 14px; cursor: pointer; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; font-weight: 500; transition: border-color .2s, color .2s; }
  .ord__retbtn:hover, .ord__cancelbtn:hover { border-color: #8B1A1A; color: #8B1A1A; }
  .ord__ret { display: inline-block; margin-top: 12px; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: #3D6B4F; font-weight: 600; }
  .ord__cancelled { display: inline-block; margin-top: 12px; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: #8B1A1A; font-weight: 600; }
  .ord-group__title { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: #9a9a9a; font-weight: 600; margin: 10px 0 0; padding-top: 18px; border-top: 1px solid #ececec; }

  /* Amazon-style shipment tracker */
  .track { display: flex; margin: 16px 0 4px; }
  .track__step { flex: 1; text-align: center; position: relative; }
  .track__step:not(:first-child)::before { content: ''; position: absolute; top: 5px; left: -50%; width: 100%; height: 2px; background: #e6e6e6; z-index: 0; }
  .track__step.done:not(:first-child)::before { background: #3D6B4F; }
  .track__dot { position: relative; z-index: 1; display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: #e6e6e6; }
  .track__step.done .track__dot { background: #3D6B4F; }
  .track__lbl { display: block; font-size: 9px; letter-spacing: .04em; text-transform: uppercase; color: #9a9a9a; margin-top: 6px; }
  .track__step.done .track__lbl { color: #1a1a1a; }
  .track__eta { font-size: 12px; color: #6b6b6b; margin: 8px 0 2px; }
  .track__link { display: inline-block; margin-top: 10px; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; font-weight: 600; color: #1a1a1a; border-bottom: 1px solid #1a1a1a; padding-bottom: 2px; transition: color .2s, border-color .2s; }
  .track__link:hover { color: #8B1A1A; border-color: #8B1A1A; }
</style>
