---
import { getCart } from '~/lib/shopify/cart';
import { getCartId } from '~/lib/cart-session';
import { shopifyImage } from '~/lib/shopifyImage';
import { formatMoney } from '~/lib/markets';
import SiteFooter from './SiteFooter.astro';

const { market, marketConfig } = Astro.locals;
const prefix = marketConfig.urlPrefix;
const homeHref = prefix || '/';
const shopHref = `${prefix}/shop`;

// Cart is per-visitor — never cache it on the CDN.
Astro.response.headers.set('Cache-Control', 'private, no-store');

const cartId = getCartId(Astro.cookies, market);
const cart = cartId ? await getCart(market, cartId, marketConfig.countryCode) : null;
const lines = cart?.lines ?? [];
const count = cart?.totalQuantity ?? 0;
const currency = cart?.currency || marketConfig.currency;
const money = (n: number) => formatMoney({ amount: String(n), currencyCode: currency }, marketConfig.locale);
const checkoutHref = market === 'india' ? '/checkout' : (cart?.checkoutUrl ?? '#');
---

<div class="sheet cart-page" data-market={market}>

  <header class="head">
    <a href={homeHref} class="head-logo" aria-label="Mir Kash"><img src="/mir-kash-logo.webp" alt="Mir Kash" /></a>
    <a href="/account" class="head-bag" aria-label="Account">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8" r="4"></circle><path d="M4 21c0-4 4-6 8-6s8 2 8 6"></path></svg>
    </a>
  </header>

  <div class="cart-wrap">
    <h1 class="cart-h1">Your bag <span class="cart-h1__c">({count})</span></h1>

    {lines.length === 0 ? (
      <div class="cart-empty">
        <p class="cart-empty__txt">Your bag is empty.</p>
        <a class="btn-cta cart-empty__cta" href={shopHref}><span>Shop the collection</span><span class="arrow"></span></a>
      </div>
    ) : (
      <>
        <div class="c-items">
          {lines.map((line) => (
            <div class="c-item" data-line-id={line.id}>
              <a class="c-thumb" href={`${prefix}/products/${line.handle}`}>
                {line.image && <img src={shopifyImage(line.image, 200)} alt={line.title} />}
              </a>
              <div class="c-info">
                <a class="c-name" href={`${prefix}/products/${line.handle}`}>{line.title}</a>
                {line.variantTitle && !/default title/i.test(line.variantTitle) && (
                  <div class="c-meta">{line.variantTitle}</div>
                )}
                <div class="c-bottom">
                  <div class="qty-control" data-line-id={line.id}>
                    <button class="qty-control__btn" data-act="dec" aria-label="Decrease quantity">−</button>
                    <span class="qty-control__val">{line.quantity}</span>
                    <button class="qty-control__btn" data-act="inc" aria-label="Increase quantity">+</button>
                  </div>
                  <span class="c-price">{money(line.lineTotal)}</span>
                </div>
                <button class="c-remove" data-act="remove" data-line-id={line.id}>Remove</button>
              </div>
            </div>
          ))}
        </div>

        <div class="c-summary">
          <div class="c-coupon">
            <input class="c-coupon__input" id="couponInput" placeholder="Discount code" value={cart!.discountCode ?? ''} autocomplete="off" autocapitalize="characters" />
            <button class="c-coupon__btn" type="button" id="couponBtn" data-applied={cart!.discountCode ? '1' : '0'}>{cart!.discountCode ? 'Remove' : 'Apply'}</button>
          </div>
          <p class="c-coupon__err" id="couponErr" hidden></p>
          <div class="tot-row"><span class="tot-k">Subtotal</span><span class="tot-v">{money(cart!.subtotal)}</span></div>
          <div class="tot-row" id="discountRow" style={cart!.discountAmount > 0 ? '' : 'display:none'}>
            <span class="tot-k">Discount <span id="discountLbl">{cart!.discountCode}</span></span>
            <span class="tot-v" id="discountVal" style="color:var(--green);font-weight:500;">−{money(cart!.discountAmount)}</span>
          </div>
          <div class="tot-row"><span class="tot-k">Shipping</span><span class="tot-v" style="font-size:12px;color:var(--mid);">Calculated at checkout</span></div>
          <div class="tot-row grand"><span class="tot-k">Total</span><span class="tot-v" id="cartGrand">{money(cart!.total)}</span></div>
          <a class="btn-cta" href={checkoutHref}><span>Checkout</span><span class="arrow"></span></a>
          <div class="c-trust">
            <span>Secure checkout</span><span class="c-dot">·</span><span>Easy returns</span>
          </div>
          <a class="c-continue" href={shopHref}>Continue shopping</a>
        </div>
      </>
    )}
  </div>
</div>

<SiteFooter />

<script define:vars={{ store: market, currency }}>
  const main = document.querySelector('.cart-page');

  async function mutate(path, payload) {
    const res = await fetch(path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ...payload, store }),
    });
    if (!res.ok) throw new Error('cart op failed');
    return res.json();
  }

  function busy(on) { if (main) main.style.opacity = on ? '0.55' : ''; }

  main?.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-act]');
    if (!btn) return;
    const act = btn.dataset.act;
    const lineId = btn.dataset.lineId || btn.closest('[data-line-id]')?.dataset.lineId;
    if (!lineId) return;

    try {
      busy(true);
      if (act === 'remove') {
        await mutate('/api/cart/remove', { lineId });
      } else if (act === 'inc' || act === 'dec') {
        const valEl = btn.closest('.qty-control').querySelector('.qty-control__val');
        const current = parseInt(valEl.textContent, 10) || 1;
        const next = act === 'inc' ? current + 1 : current - 1;
        await mutate('/api/cart/update', { lineId, quantity: next });
      } else {
        return;
      }
      window.location.reload();
    } catch {
      busy(false);
      alert('Sorry — could not update your bag. Please try again.');
    }
  });

  // ── Coupon ──
  const fmtMoney = (n) => {
    try { return new Intl.NumberFormat('en-IN', { style: 'currency', currency, maximumFractionDigits: 0 }).format(Math.round(n)); }
    catch { return currency + ' ' + Math.round(n).toLocaleString('en-IN'); }
  };
  const couponBtn = document.getElementById('couponBtn');
  couponBtn?.addEventListener('click', async () => {
    const input = document.getElementById('couponInput');
    const err = document.getElementById('couponErr');
    const removing = couponBtn.dataset.applied === '1';
    const code = removing ? '' : input.value.trim();
    if (!removing && !code) return;
    err.hidden = true;
    couponBtn.disabled = true; couponBtn.textContent = removing ? 'Removing…' : 'Applying…';
    try {
      const res = await fetch('/api/cart/apply-discount', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store, code }),
      });
      const data = await res.json();
      if (data.ok === false) { err.textContent = data.error || 'Invalid code.'; err.hidden = false; couponBtn.disabled = false; couponBtn.textContent = 'Apply'; return; }
      if (!res.ok) throw new Error();
      const row = document.getElementById('discountRow');
      if (data.discount > 0 && data.code) {
        row.style.display = '';
        document.getElementById('discountLbl').textContent = data.code;
        document.getElementById('discountVal').textContent = '−' + fmtMoney(data.discount);
        couponBtn.dataset.applied = '1'; couponBtn.textContent = 'Remove'; input.value = data.code;
      } else {
        row.style.display = 'none';
        couponBtn.dataset.applied = '0'; couponBtn.textContent = 'Apply'; input.value = '';
      }
      document.getElementById('cartGrand').textContent = fmtMoney(data.total);
    } catch {
      err.textContent = 'Could not apply the code. Please try again.'; err.hidden = false;
      couponBtn.textContent = removing ? 'Remove' : 'Apply';
    } finally {
      couponBtn.disabled = false;
    }
  });
</script>

<style is:global>
  :root {
    --font: 'Jost', -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --serif: var(--font);
    --cherry: #8B1A1A; --depth: #1a1a1a; --cream: #ffffff;
    --rule: #e6e6e6; --ink: #141414; --mid: #6b6b6b; --soft: #a3a3a3; --green: #3D6B4F; --caps: .13em;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--font); color: var(--ink); background: #fff; font-size: 14px; line-height: 1.5; min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
  body > .site-footer { width: 100%; }

  .sheet { flex: 0 0 auto; width: 100%; max-width: 460px; background: #fff; min-height: 100vh; box-shadow: 0 0 0 1px rgba(0,0,0,.05), 0 30px 80px rgba(0,0,0,.07); transition: opacity .2s; }
  @media (max-width: 480px) { .sheet { box-shadow: none; } }

  .head { display: flex; align-items: center; justify-content: space-between; padding: 20px 22px 18px; border-bottom: 1px solid var(--rule); position: sticky; top: 0; background: #fff; z-index: 20; }
  .head-logo img { height: 19px; display: block; filter: brightness(0); }
  .head-bag { width: 38px; height: 38px; border: 1px solid var(--rule); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--depth); }

  .cart-wrap { padding: 26px 22px 60px; }
  .cart-h1 { font-family: var(--serif); font-weight: 400; font-size: 26px; color: var(--depth); margin-bottom: 24px; }
  .cart-h1__c { color: var(--soft); }

  .c-item { display: grid; grid-template-columns: 84px 1fr; gap: 16px; padding: 20px 0; border-top: 1px solid var(--rule); position: relative; }
  .c-item:first-child { border-top: none; padding-top: 0; }
  .c-thumb { display: block; width: 84px; aspect-ratio: 4/5; background: var(--cream); overflow: hidden; }
  .c-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .c-info { display: flex; flex-direction: column; }
  .c-name { font-size: 11.5px; letter-spacing: .07em; text-transform: uppercase; font-weight: 500; color: var(--depth); line-height: 1.3; }
  .c-name:hover { color: var(--cherry); }
  .c-meta { font-family: var(--serif); font-size: 13px; color: var(--mid); margin-top: 3px; }
  .c-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 14px; }
  .qty-control { display: flex; align-items: center; border: 1px solid var(--rule); height: 34px; }
  .qty-control__btn { width: 32px; height: 100%; background: none; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--depth); font-size: 15px; transition: color .2s, background .2s; }
  .qty-control__btn:hover { background: rgba(0,0,0,.03); color: var(--cherry); }
  .qty-control__val { width: 34px; text-align: center; font-family: var(--serif); font-size: 14px; border-left: 1px solid var(--rule); border-right: 1px solid var(--rule); height: 100%; display: flex; align-items: center; justify-content: center; }
  .c-price { font-family: var(--serif); font-size: 15px; color: var(--depth); }
  .c-remove { position: absolute; top: 20px; right: 0; background: none; border: none; cursor: pointer; color: var(--soft); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; transition: color .2s; }
  .c-item:first-child .c-remove { top: 0; }
  .c-remove:hover { color: var(--cherry); }

  .c-summary { margin-top: 26px; padding-top: 22px; border-top: 1px solid var(--depth); }
  .c-coupon { display: flex; gap: 8px; margin-bottom: 16px; }
  .c-coupon__input { flex: 1; border: 1px solid var(--rule); padding: 0 12px; height: 42px; font-size: 13px; font-family: inherit; outline: none; text-transform: uppercase; letter-spacing: .04em; background: #fff; color: var(--ink); }
  .c-coupon__input:focus { border-color: var(--depth); }
  .c-coupon__input::placeholder { text-transform: none; letter-spacing: 0; color: var(--soft); }
  .c-coupon__btn { flex-shrink: 0; height: 42px; padding: 0 18px; background: none; border: 1px solid var(--depth); cursor: pointer; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; color: var(--depth); transition: background .2s, color .2s; }
  .c-coupon__btn:hover:not(:disabled) { background: var(--depth); color: #fff; }
  .c-coupon__btn:disabled { opacity: .5; cursor: default; }
  .c-coupon__err { color: var(--cherry); font-size: 12px; margin: -8px 0 14px; }
  .tot-row { display: flex; justify-content: space-between; align-items: baseline; padding: 5px 0; }
  .tot-k { font-size: 10.5px; letter-spacing: .1em; text-transform: uppercase; font-weight: 500; color: var(--mid); }
  .tot-v { font-family: var(--serif); font-size: 14px; color: var(--depth); }
  .tot-row.grand { margin-top: 8px; padding-top: 12px; border-top: 1px solid rgba(0,0,0,.1); }
  .tot-row.grand .tot-k { color: var(--depth); font-size: 11px; }
  .tot-row.grand .tot-v { font-size: 19px; }

  .btn-cta { width: 100%; height: 52px; background: var(--depth); color: #fff; border: none; cursor: pointer; font-size: 11px; letter-spacing: var(--caps); text-transform: uppercase; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 13px; transition: background .22s; margin-top: 18px; }
  .btn-cta:hover { background: var(--cherry); }
  .arrow { display: block; width: 22px; height: 1px; background: currentColor; position: relative; transition: width .2s; }
  .arrow::after { content: ''; position: absolute; right: -1px; top: -2.5px; width: 6px; height: 6px; border-top: 1px solid currentColor; border-right: 1px solid currentColor; transform: rotate(45deg); }
  .btn-cta:hover .arrow { width: 30px; }

  .c-trust { display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 16px; font-size: 9.5px; letter-spacing: .1em; text-transform: uppercase; color: var(--soft); }
  .c-trust .c-dot { opacity: .6; }
  .c-continue { display: block; text-align: center; margin-top: 18px; font-family: var(--serif); font-size: 14px; color: var(--mid); }
  .c-continue:hover { color: var(--cherry); }

  .cart-empty { text-align: center; padding: 60px 0; }
  .cart-empty__txt { font-family: var(--serif); font-size: 18px; color: var(--mid); margin-bottom: 26px; }
  .cart-empty__cta { max-width: 280px; margin: 0 auto; }
</style>
