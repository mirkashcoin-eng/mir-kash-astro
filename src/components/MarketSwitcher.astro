---
import { listMarkets, getAlternateUrl } from '~/lib/markets';
import type { Market } from '~/types/market';

const { market } = Astro.locals;
const pathname = Astro.url.pathname;

const markets = listMarkets();
const current = markets.find((m) => m.market === market)!;

const options = markets.map((m) => ({
  market: m.market,
  label: m.label,
  flag: m.flag,
  href: getAlternateUrl(pathname, m.market as Market),
  active: m.market === market,
}));
---
<div class="market-switcher" data-current={current.market}>
  <button class="market-switcher__btn" aria-haspopup="listbox" aria-expanded="false" type="button">
    <span class="market-switcher__flag" aria-hidden="true">{current.flag}</span>
    <span class="market-switcher__label">{current.label}</span>
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </button>
  <ul class="market-switcher__menu" role="listbox">
    {options.map((o) => (
      <li role="option" aria-selected={o.active}>
        <a href={o.href} data-market-link={o.market}>
          <span aria-hidden="true">{o.flag}</span>
          <span>{o.label}</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .market-switcher {
    position: relative;
    display: inline-flex;
  }
  .market-switcher__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 8px;
    color: inherit;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .market-switcher__btn:hover { color: var(--cherry, #8B1A1A); }
  .market-switcher__flag { font-size: 13px; line-height: 1; }
  .market-switcher__menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--paper, #F5F0E8);
    border: 1px solid var(--rule, #e4dfd7);
    list-style: none;
    margin: 0;
    padding: 6px 0;
    min-width: 160px;
    box-shadow: 0 4px 20px rgba(0,0,0,.08);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity .2s ease, transform .2s ease;
    z-index: 250;
  }
  .market-switcher.is-open .market-switcher__menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .market-switcher__menu li a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--depth, #2C1A0E);
    transition: background .15s, color .15s;
  }
  .market-switcher__menu li[aria-selected="true"] a { color: var(--cherry, #8B1A1A); }
  .market-switcher__menu li a:hover { background: rgba(0,0,0,.04); color: var(--cherry, #8B1A1A); }
</style>

<script>
  document.querySelectorAll('.market-switcher').forEach((root) => {
    const btn = root.querySelector('.market-switcher__btn') as HTMLButtonElement | null;
    if (!btn) return;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = root.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        root.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
    root.querySelectorAll('[data-market-link]').forEach((link) => {
      link.addEventListener('click', () => {
        const m = (link as HTMLAnchorElement).dataset.marketLink;
        if (m) {
          document.cookie = `mirkash-market=${m}; path=/; max-age=${60 * 60 * 24 * 365}; samesite=lax`;
        }
      });
    });
  });
</script>
