---
import { getCart } from '~/lib/shopify/cart';
import { resolveCheckoutCartId } from '~/lib/cart-session';
import { shopifyImage } from '~/lib/shopifyImage';

// Custom checkout = INDIA store only. Design ported from Rahul's
// "Mir Kash Checkout (standalone).html" (accordion: Contact → Delivery → Payment).
const store = 'india' as const;
const isBuyNow = Astro.url.searchParams.get('buynow') === '1';

Astro.response.headers.set('Cache-Control', 'private, no-store');

const cartId = resolveCheckoutCartId(Astro.cookies, store, isBuyNow);
const cart = cartId ? await getCart(store, cartId) : null;
if (!cart || cart.lines.length === 0) {
  return Astro.redirect('/cart');
}

// Indian digit grouping (₹1,09,700) to match the design.
const inr = (n: number) => '₹' + Math.round(n).toLocaleString('en-IN');
const count = cart.totalQuantity;
const thumbGradients = [
  'linear-gradient(160deg,#c4938f,#8b1a1a)',
  'linear-gradient(160deg,#a0808a,#5c2d3e)',
  'linear-gradient(160deg,#e8ddd0,#c4a87a)',
  'linear-gradient(160deg,#b9c2bd,#5c6b62)',
];
---

<div class="sheet" data-buynow={isBuyNow ? '1' : '0'} data-total={cart.total}>

  <header class="head">
    <a href="/" class="head-logo" aria-label="Mir Kash">
      <img src="/mir-kash-logo.webp" alt="Mir Kash" />
    </a>
    <a href="/cart" class="head-bag" aria-label="Your bag">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
      <span class="count">{count}</span>
    </a>
  </header>

  <!-- ORDER SUMMARY -->
  <div class="summary">
    <div class="summary-bar" id="sumBar">
      <span class="summary-l">
        Order summary
        <svg class="summary-chev" id="sumChev" width="11" height="7" viewBox="0 0 11 7" fill="none"><path d="M1 1L5.5 5.5L10 1" stroke="currentColor" stroke-width="1.3"></path></svg>
      </span>
      <span class="summary-amt" id="sumAmt">{inr(cart.total)}</span>
    </div>
    <div class="summary-body" id="sumBody">
      <div class="summary-inner">
        {cart.lines.map((line, i) => (
          <div class="sum-item" data-line-id={line.id}>
            <div class="sum-thumb" style={line.image ? `background:#f5f2ed url('${shopifyImage(line.image, 120)}') center/cover;` : `background:${thumbGradients[i % thumbGradients.length]};`}>
              <span class="qty">{line.quantity}</span>
            </div>
            <div>
              <div class="sum-name">{line.title}</div>
              {line.variantTitle && !/default title/i.test(line.variantTitle) && (
                <div class="sum-meta">{line.variantTitle}</div>
              )}
              <button class="sum-remove" type="button" data-remove={line.id}>Remove</button>
            </div>
            <div class="sum-price">{inr(line.lineTotal)}</div>
          </div>
        ))}
        <div class="sum-coupon">
          <input class="input" id="couponInput" placeholder="Discount code" value={cart.discountCode ?? ''} autocomplete="off" autocapitalize="characters" />
          <button class="coupon-btn" type="button" id="couponBtn" data-applied={cart.discountCode ? '1' : '0'}>{cart.discountCode ? 'Remove' : 'Apply'}</button>
        </div>
        <p class="co-err" id="err-coupon" hidden></p>
        <div class="sum-tots">
          <div class="tot-row"><span class="tot-k">Subtotal</span><span class="tot-v">{inr(cart.subtotal)}</span></div>
          <div class="tot-row" id="discountRow" style={cart.discountAmount > 0 ? '' : 'display:none'}>
            <span class="tot-k">Discount <span id="discountLbl">{cart.discountCode}</span></span>
            <span class="tot-v" id="discountVal" style="color:var(--green);font-weight:500;">−{inr(cart.discountAmount)}</span>
          </div>
          <div class="tot-row"><span class="tot-k">Shipping</span><span class="tot-v free">Free &nbsp;·&nbsp; 5–7 days</span></div>
          <div class="tot-row grand"><span class="tot-k">Total</span><span class="tot-v" id="sumGrand">{inr(cart.total)}</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ACCORDION FLOW -->
  <div class="flow">

    <!-- 1 · CONTACT -->
    <section class="acc" data-state="active" id="acc-contact">
      <button class="acc-head" type="button" data-edit="contact">
        <span class="acc-marker"><span class="num">1</span><span class="chk">✓</span></span>
        <span class="acc-head-txt">
          <span class="acc-title">Contact</span>
          <span class="acc-recap" id="recap-contact"></span>
        </span>
        <span class="acc-edit">Edit</span>
      </button>
      <div class="acc-body"><div class="acc-body-inner">
        <div class="field" style="margin-bottom:0;">
          <div class="label-row">
            <label class="field-label" for="f-phone">Mobile number</label>
            <button class="signin-link" type="button" id="signinBtn" hidden>Have an account? <u>Sign in</u></button>
          </div>
          <div class="phone-wrap">
            <span class="phone-cc">+91</span>
            <input class="input" type="tel" id="f-phone" placeholder="98765 43210" maxlength="10" inputmode="numeric" autocomplete="tel-national" />
          </div>
        </div>
        <p class="fine">Order &amp; shipping updates by text. See our <a href="/policies">Privacy policy</a>.</p>
        <p class="co-err" id="err-contact" hidden></p>
        <button class="btn-cta" type="button" data-complete="contact" style="margin-top:24px;">
          <span>Continue to delivery</span><span class="arrow"></span>
        </button>
      </div></div>
    </section>

    <!-- 2 · DELIVERY -->
    <section class="acc" data-state="todo" id="acc-delivery">
      <button class="acc-head" type="button" data-edit="delivery">
        <span class="acc-marker"><span class="num">2</span><span class="chk">✓</span></span>
        <span class="acc-head-txt">
          <span class="acc-title">Delivery</span>
          <span class="acc-recap" id="recap-delivery"></span>
        </span>
        <span class="acc-edit">Edit</span>
      </button>
      <div class="acc-body"><div class="acc-body-inner">

        <div class="ship-strip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <span>Free shipping across India &nbsp;·&nbsp; arrives in 5–7 business days</span>
        </div>

        <!-- Saved address (appears after sign-in — Phase C) -->
        <div class="saved-card" id="savedCard">
          <span class="saved-radio"></span>
          <div>
            <div class="saved-name" id="savedName"></div>
            <div class="saved-addr" id="savedAddr"></div>
          </div>
        </div>

        <div class="field">
          <label class="field-label" for="f-name">Full name</label>
          <input class="input" type="text" id="f-name" placeholder="Priya Sharma" autocomplete="name" />
        </div>

        <div class="pin-grid">
          <div class="field" style="margin-bottom:0;">
            <label class="field-label" for="f-pin">PIN code</label>
            <input class="input" type="tel" id="f-pin" placeholder="400072" maxlength="6" inputmode="numeric" />
          </div>
          <div class="field" style="margin-bottom:0;">
            <label class="field-label" for="f-citystate">City &amp; State</label>
            <input class="input" type="text" id="f-citystate" placeholder="City, State" autocomplete="address-level2" />
          </div>
        </div>
        <div class="geo-chip" id="geoChip">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 6 9 17l-5-5"></path></svg>
          <span id="geoTxt">Serviceable · delivers in 3–5 days</span>
        </div>

        <div class="field" style="margin-top:20px;">
          <label class="field-label" for="f-addr">Address</label>
          <input class="input" type="text" id="f-addr" placeholder="Flat / house no. and street" autocomplete="address-line1" />
        </div>

        <div class="add-links">
          <button class="add-link" type="button" id="lnk-apt" data-reveal="apt">+ Add apartment, suite</button>
        </div>
        <div class="reveal" id="rev-apt">
          <div class="field">
            <label class="field-label" for="f-apt">Apartment, suite, etc.</label>
            <input class="input" type="text" id="f-apt" placeholder="Building, landmark" autocomplete="address-line2" />
          </div>
        </div>

        <div class="field" style="margin-top:6px;">
          <label class="field-label" for="f-email">Email address <span class="opt">· for order confirmation</span></label>
          <input class="input" type="email" id="f-email" placeholder="you@example.com" autocomplete="email" />
        </div>

        <p class="co-err" id="err-delivery" hidden></p>
        <button class="btn-cta" type="button" data-complete="delivery">
          <span>Continue to payment</span><span class="arrow"></span>
        </button>
      </div></div>
    </section>

    <!-- 3 · PAYMENT -->
    <section class="acc" data-state="todo" id="acc-payment">
      <button class="acc-head" type="button" data-edit="payment">
        <span class="acc-marker"><span class="num">3</span><span class="chk">✓</span></span>
        <span class="acc-head-txt">
          <span class="acc-title">Payment</span>
          <span class="acc-recap" id="recap-payment"></span>
        </span>
        <span class="acc-edit">Edit</span>
      </button>
      <div class="acc-body"><div class="acc-body-inner">

        <div class="pay-opt sel" data-pay="upi">
          <div class="pay-opt-head">
            <span class="pay-icon"><svg viewBox="0 0 60 28" width="30" height="14"><text x="0" y="22" font-family="Arial" font-weight="900" font-size="24" fill="#5F259F">UPI</text></svg></span>
            <span class="pay-name">Pay via UPI<span class="pay-desc">GPay, PhonePe, Paytm &amp; more</span></span>
            <span class="pay-radio"></span>
          </div>
        </div>

        <div class="pay-opt" data-pay="card">
          <div class="pay-opt-head">
            <span class="pay-icon"><svg width="22" height="14" viewBox="0 0 24 24" fill="none" stroke="#6e6a64" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg></span>
            <span class="pay-name">Card<span class="pay-desc">Visa, Mastercard, RuPay &amp; Amex</span></span>
            <span class="pay-radio"></span>
          </div>
        </div>

        <p class="pay-note">
          <svg width="11" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          You'll complete payment securely with Cashfree (UPI · cards · netbanking).
        </p>

        <p class="co-err" id="err-payment" hidden></p>
        <button class="btn-cta" id="placeBtn" type="button" style="margin-top:18px;">
          <span id="placeTxt">She's yours — pay {inr(cart.total)}</span><span class="arrow"></span>
        </button>
      </div></div>
    </section>

  </div>

  <div class="secured-note">
    <svg width="10" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
    Secure checkout · Mir Kash
  </div>
</div>

<script>
  import { load } from '@cashfreepayments/cashfree-js';
  import { getSessionUser, loadProfile, signInWithGoogle, saveLead, firebaseConfigured } from '~/lib/firebaseClient';

  const $ = (id: string) => document.getElementById(id) as HTMLElement;
  const sheet = document.querySelector('.sheet') as HTMLElement;
  const buyNow = sheet?.dataset.buynow === '1';

  const ORDER = ['contact', 'delivery', 'payment'];
  let active = 'contact';
  const done = new Set<string>();

  function setState(id: string, s: string) { ($('acc-' + id) as HTMLElement).dataset.state = s; }
  function renderFlow() {
    ORDER.forEach((id) => setState(id, id === active ? 'active' : (done.has(id) ? 'done' : 'todo')));
  }
  function openSection(id: string) { active = id; renderFlow(); }
  function scrollToSection(id: string) {
    const y = ($('acc-' + id) as HTMLElement).getBoundingClientRect().top + window.pageYOffset - 8;
    window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
  }

  function showErr(id: string, msg: string) { const e = $('err-' + id); e.textContent = msg; e.hidden = false; }
  function clearErr(id: string) { $('err-' + id).hidden = true; }

  const val = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value.trim() ?? '';
  function phone10() { return val('f-phone').replace(/\D/g, '').slice(-10); }
  function splitCityState(s: string) {
    const i = s.lastIndexOf(',');
    return i >= 0 ? { city: s.slice(0, i).trim(), province: s.slice(i + 1).trim() } : { city: s.trim(), province: '' };
  }

  function buildRecap(id: string) {
    const el = $('recap-' + id);
    if (id === 'contact') el.textContent = '+91 ' + phone10();
    else if (id === 'delivery') el.textContent = [val('f-name'), val('f-addr'), val('f-citystate')].filter(Boolean).join(' · ') || 'Address added';
    else if (id === 'payment') el.textContent = (document.querySelector('.pay-opt.sel') as HTMLElement)?.dataset.pay === 'card' ? 'Card' : 'UPI';
  }

  // ── Accordion edit / complete ──
  document.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => {
    const id = (b as HTMLElement).dataset.edit!;
    if (done.has(id) || id === active) openSection(id);
  }));

  $('err-contact'); // ensure exists
  document.querySelector('[data-complete="contact"]')!.addEventListener('click', () => {
    clearErr('contact');
    if (phone10().length !== 10) { showErr('contact', 'Enter a valid 10-digit mobile number.'); return; }
    // Lead capture to Firestore (best-effort)
    saveLead(phone10());
    done.add('contact'); buildRecap('contact'); active = 'delivery'; renderFlow(); scrollToSection('delivery');
  });

  document.querySelector('[data-complete="delivery"]')!.addEventListener('click', () => {
    clearErr('delivery');
    if (!val('f-name') || !val('f-addr') || !/^\d{6}$/.test(val('f-pin'))) { showErr('delivery', 'Please fill name, address and a valid 6-digit PIN.'); return; }
    if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(val('f-email'))) { showErr('delivery', 'Enter a valid email for your confirmation.'); return; }
    done.add('delivery'); buildRecap('delivery'); active = 'payment'; renderFlow(); scrollToSection('payment');
  });

  // ── Summary toggle ──
  let sumOpen = false;
  $('sumBar').addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('[data-remove]')) return;
    sumOpen = !sumOpen;
    $('sumBody').classList.toggle('open', sumOpen);
    $('sumChev').classList.toggle('open', sumOpen);
  });

  // ── Remove a bag ──
  document.querySelector('.summary-inner')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-remove]');
    if (!btn) return;
    e.stopPropagation();
    btn.disabled = true; btn.textContent = 'Removing…';
    try {
      const res = await fetch('/api/cart/remove', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ lineId: btn.dataset.remove, store: 'india', buynow: buyNow }) });
      if (!res.ok) throw new Error();
      window.location.reload();
    } catch { btn.disabled = false; btn.textContent = 'Remove'; alert('Could not remove that item.'); }
  });

  // ── Coupon ──
  const inrFmt = (n: number) => '₹' + Math.round(n).toLocaleString('en-IN');
  $('couponBtn').addEventListener('click', async () => {
    const btn = $('couponBtn') as HTMLButtonElement;
    const input = document.getElementById('couponInput') as HTMLInputElement;
    const removing = btn.dataset.applied === '1';
    const code = removing ? '' : input.value.trim();
    if (!removing && !code) return;
    clearErr('coupon');
    btn.disabled = true; btn.textContent = removing ? 'Removing…' : 'Applying…';
    try {
      const res = await fetch('/api/checkout/apply-discount', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, buynow: buyNow }),
      });
      const data = await res.json();
      if (data.ok === false) { showErr('coupon', data.error || 'Invalid code.'); btn.disabled = false; btn.textContent = 'Apply'; return; }
      if (!res.ok) throw new Error();
      // Update totals
      const row = $('discountRow');
      if (data.discount > 0 && data.code) {
        row.style.display = '';
        $('discountLbl').textContent = data.code;
        $('discountVal').textContent = '−' + inrFmt(data.discount);
        btn.dataset.applied = '1'; btn.textContent = 'Remove'; input.value = data.code;
      } else {
        row.style.display = 'none';
        btn.dataset.applied = '0'; btn.textContent = 'Apply'; input.value = '';
      }
      $('sumGrand').textContent = inrFmt(data.total);
      $('sumAmt').textContent = inrFmt(data.total);
      $('placeTxt').textContent = 'She’s yours — pay ' + inrFmt(data.total);
      sheet.dataset.total = String(data.total);
    } catch {
      showErr('coupon', 'Could not apply the code. Please try again.');
    } finally {
      btn.disabled = false;
      if (btn.textContent === 'Applying…' || btn.textContent === 'Removing…') btn.textContent = removing ? 'Apply' : 'Apply';
    }
  });

  // ── PIN → city/state autofill ──
  const PINS: Record<string, string> = {
    '4000': 'Mumbai, Maharashtra', '4100': 'Pune, Maharashtra', '1100': 'New Delhi, Delhi',
    '1220': 'Gurugram, Haryana', '5600': 'Bengaluru, Karnataka', '6000': 'Chennai, Tamil Nadu',
    '3800': 'Ahmedabad, Gujarat', '7000': 'Kolkata, West Bengal', '5000': 'Hyderabad, Telangana',
    '3020': 'Jaipur, Rajasthan', '6820': 'Kochi, Kerala', '1600': 'Chandigarh, Punjab',
  };
  $('f-pin').addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    const v = input.value.replace(/\D/g, '').substring(0, 6);
    input.value = v;
    const chip = $('geoChip');
    const cs = document.getElementById('f-citystate') as HTMLInputElement;
    if (v.length === 6) {
      const loc = PINS[v.substring(0, 4)];
      if (loc && !cs.value) cs.value = loc;
      chip.classList.add('show');
    } else { chip.classList.remove('show'); }
  });

  // ── Optional field reveal ──
  document.querySelectorAll('[data-reveal]').forEach((b) => b.addEventListener('click', () => {
    const w = (b as HTMLElement).dataset.reveal!;
    $('rev-' + w).classList.add('show');
    (b as HTMLElement).classList.add('hidden');
  }));

  // ── Payment method pick ──
  document.querySelectorAll('.pay-opt').forEach((o) => o.addEventListener('click', () => {
    document.querySelectorAll('.pay-opt').forEach((x) => x.classList.remove('sel'));
    o.classList.add('sel');
    if (done.has('payment')) buildRecap('payment');
  }));

  // ── Place order → Cashfree ──
  $('placeBtn').addEventListener('click', async () => {
    clearErr('payment');
    const btn = $('placeBtn') as HTMLButtonElement;
    btn.disabled = true;
    $('placeTxt').textContent = 'Starting secure payment…';
    const { city, province } = splitCityState(val('f-citystate'));
    try {
      const res = await fetch('/api/checkout/create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fullName: val('f-name'), address1: val('f-addr'), address2: val('f-apt'),
          city, province, zip: val('f-pin'), email: val('f-email'), phone: phone10(), buynow: buyNow,
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.paymentSessionId) throw new Error(data.error || 'Could not start payment');
      const cashfree = await load({ mode: data.mode });
      await cashfree.checkout({ paymentSessionId: data.paymentSessionId, redirectTarget: '_self' });
    } catch (err) {
      console.error(err);
      showErr('payment', 'Payment could not be started. Please try again.');
      btn.disabled = false;
      $('placeTxt').textContent = 'She’s yours — pay ' + (sheet.dataset.total ? '₹' + Math.round(Number(sheet.dataset.total)).toLocaleString('en-IN') : '');
    }
  });

  renderFlow();

  // ── Account: sign-in + saved-address pre-fill ──
  if (firebaseConfigured()) {
    const sBtn = $('signinBtn');
    if (sBtn) {
      sBtn.hidden = false;
      sBtn.addEventListener('click', async () => { try { await signInWithGoogle(); location.reload(); } catch {} });
    }
    const setVal = (id: string, value?: string | null) => { const el = document.getElementById(id) as HTMLInputElement; if (el && value) el.value = value; };
    (async () => {
      const user = await getSessionUser();
      if (!user) return;
      if (sBtn) sBtn.hidden = true;
      const p = await loadProfile(user.uid);
      if (!p) { setVal('f-email', user.email); return; }
      setVal('f-phone', (p.phone || '').replace(/\D/g, '').slice(-10));
      setVal('f-name', p.full_name);
      setVal('f-addr', p.address1);
      setVal('f-apt', p.address2);
      setVal('f-pin', p.zip);
      setVal('f-email', p.email || user.email);
      setVal('f-citystate', [p.city, p.province].filter(Boolean).join(', '));
      if (p.address2) { $('rev-apt').classList.add('show'); $('lnk-apt').classList.add('hidden'); }
      const card = $('savedCard');
      if (card && (p.address1 || p.full_name)) {
        $('savedName').textContent = p.full_name || user.email || '';
        $('savedAddr').innerHTML = [p.address1, [p.city, p.province, p.zip].filter(Boolean).join(', ')].filter(Boolean).join('<br>');
        card.classList.add('show');
      }
    })();
  }
</script>

<style is:global>
  :root {
    --styrene: 'Jost', -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --serif: var(--styrene); --font: var(--styrene);
    --cherry: #8B1A1A; --depth: #1a1a1a; --paper: #ffffff; --cream: #f5f5f5; --white: #ffffff;
    --rule: #e6e6e6; --ink: #141414; --mid: #6b6b6b; --soft: #a3a3a3; --green: #3D6B4F; --caps: 0.13em;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  body { font-family: var(--font); color: var(--ink); background: var(--paper); font-size: 14px; line-height: 1.5; min-height: 100vh; display: flex; justify-content: center; padding-top: 0; }
  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; }
  input, select, textarea { font-family: inherit; }

