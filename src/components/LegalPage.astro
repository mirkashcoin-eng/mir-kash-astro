---
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';

interface Props {
  heading: string;
}
const { heading } = Astro.props;
---
<SiteHeader />

<main class="legal">
  <div class="legal__inner">
    <p class="legal__eyebrow">Legal</p>
    <h1 class="legal__title">{heading}</h1>
    <div class="legal__body">
      <slot />
    </div>
  </div>
</main>

<SiteFooter />

<style is:global>
  :root {
    --serif: 'Jost', -apple-system, 'Helvetica Neue', sans-serif;
    --cherry: #8B1A1A;
    --depth: #2C1A0E;
  }
  body { background: var(--paper); }

  /* Legal pages use the solid header with the hamburger hidden (the nav row replaces
     it). With the menu button gone, place the logo centered and the account/bag
     actions hard-right so row 1 matches the rest of the site. */
  .hdr-menu-btn { display: none; }
  .site-header--minimal .logo { grid-column: 2; justify-self: center; }
  .site-header--minimal .logo img { height: 22px; }
  .site-header--minimal .hdr-right { grid-column: 3; justify-self: end; gap: 14px; }

  .legal {
    background: var(--paper);
    color: var(--depth);
    padding: clamp(40px, 6vw, 88px) var(--gutter) clamp(64px, 8vw, 120px);
  }
  .legal__inner { max-width: 760px; margin: 0 auto; }
  .legal__eyebrow {
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--cherry);
    margin-bottom: 14px;
  }
  .legal__title {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--depth);
  }
  .legal__title::after {
    content: '';
    display: block;
    width: 56px;
    height: 1px;
    background: var(--cherry);
    margin: clamp(20px, 3vw, 32px) 0 clamp(28px, 4vw, 48px);
  }

  .legal__body { font-size: 15px; line-height: 1.7; color: #3a3128; }
  .legal__body h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 26px);
    color: var(--depth);
    letter-spacing: 0;
    margin: 38px 0 12px;
  }
  .legal__body h2:first-child { margin-top: 0; }
  .legal__body h3 {
    font-size: 13px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    font-weight: 600;
    color: var(--depth);
    margin: 28px 0 10px;
  }
  .legal__body p { margin: 0 0 16px; }
  .legal__body ul { list-style: disc; padding-left: 22px; margin: 0 0 16px; }
  .legal__body li { margin: 0 0 8px; }
  .legal__body strong { color: var(--depth); font-weight: 600; }
  .legal__body a {
    color: var(--cherry);
    text-decoration: underline;
    text-underline-offset: 2px;
    word-break: break-word;
  }
  .legal__body a:hover { opacity: .7; }

  @media (max-width: 768px) {
    .legal__body { font-size: 14.5px; }
  }
</style>
