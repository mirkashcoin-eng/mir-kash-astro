---
import SiteFooter from './SiteFooter.astro';
import { shopifyImage } from '~/lib/shopifyImage';
import { formatMoney } from '~/lib/markets';
import type { ProductDetail } from '~/types/shopify';

interface Props {
  product: ProductDetail;
}

const { product } = Astro.props;
const { market, marketConfig } = Astro.locals;
const prefix = marketConfig.urlPrefix;
const homeHref = prefix || '/';
const shopHref = `${prefix}/shop`;
const cartHref = `${prefix}/cart`;

// ── Images ──────────────────────────────────────────────────────────────────
const imgNodes = (product.images?.edges ?? []).map((e) => e.node);
if (imgNodes.length === 0 && product.featuredImage) imgNodes.push(product.featuredImage);
const images = imgNodes.map((n) => ({
  full: shopifyImage(n.url, 1100),
  thumb: shopifyImage(n.url, 160),
  alt: n.altText ?? product.title,
}));

// Editorial sections (story slideshow · full-bleed · lookbook) reuse the product's
// own gallery photos, cycling when there are fewer images than slots.
const galleryFulls = images.map((i) => i.full);
const pickImg = (i: number) => (galleryFulls.length ? galleryFulls[i % galleryFulls.length] : '');
const storyImgArr = [0, 1, 2, 3].map(pickImg);
const fullBleedImg = pickImg(1);
const lookImgs = [0, 1, 2].map(pickImg);

// ── Options & variants ───────────────────────────────────────────────────────
const isRealOption = (name: string, values: string[]) =>
  !(values.length === 1 && /default title/i.test(values[0]));

const colorOption = product.options.find(
  (o) => /colou?r/i.test(o.name) && isRealOption(o.name, o.values),
);
const sizeOption = product.options.find(
  (o) => /size/i.test(o.name) && isRealOption(o.name, o.values),
);

const variants = product.variants.edges.map((e) => e.node);
const variantData = variants.map((v) => ({
  id: v.id,
  available: v.availableForSale,
  price: formatMoney(v.price, marketConfig.locale),
  options: Object.fromEntries(v.selectedOptions.map((o) => [o.name, o.value])),
}));
const firstVariantId = variants[0]?.id ?? '';
const startPrice = formatMoney(product.priceRange.minVariantPrice, marketConfig.locale);

// Colour name → swatch hex (best-effort; falls back to neutral).
const COLOR_HEX: Record<string, string> = {
  taupe: '#8B7355', onyx: '#1a1a1a', black: '#1a1a1a', cognac: '#C8895A',
  stone: '#C4BFB6', plum: '#5C2D3E', tan: '#C8A06A', brown: '#6B4A2B',
  beige: '#D9CBB5', cream: '#EDE5D5', ivory: '#F0E6D3', white: '#f4f1ea',
  sand: '#D4B896', camel: '#C4882B', red: '#8B1A1A', cherry: '#8B1A1A',
  green: '#2D5016', forest: '#2D5016', navy: '#1A2340', blue: '#3A4A6B',
  grey: '#8a8a8a', gray: '#8a8a8a', pink: '#C9A09A', rose: '#C9A09A',
  fig: '#4A1942', midnight: '#1A2340',
};
const hexFor = (name: string) =>
  COLOR_HEX[name.trim().toLowerCase()] ?? '#bdb5a8';

const clientData = { variants: variantData, colorName: colorOption?.name ?? null, sizeName: sizeOption?.name ?? null };
---

<div class="ticker" aria-label="Announcements">
  <div class="ticker__track">
    {[0, 1].map((i) => (
      <div class="ticker__seq" aria-hidden={i === 1 ? 'true' : undefined}>
        <span>Handmade vegan bags</span><span class="dot">·</span>
        <span>Made slowly, worn forever</span><span class="dot">·</span>
        <span>Apple leather from Italy</span><span class="dot">·</span>
        <span>Ships worldwide</span><span class="dot">·</span>
        <span>Cruelty-free always</span><span class="dot">·</span>
      </div>
    ))}
  </div>
</div>

<header class="hdr">
  <div class="hdr__wrap">
    <div class="hdr__left" aria-hidden="true"></div>
    <a href={homeHref} class="hdr__logo"><img src="/mir-kash-logo.webp" alt="Mir Kash" /></a>
    <div class="hdr__right">
      <a class="hdr__btn hdr__bag" href={cartHref} aria-label="Bag">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        <span class="bag-count">0</span>
      </a>
    </div>
  </div>
  <nav class="hdr__nav" aria-label="Primary">
    <a href={shopHref}>Shop All</a>
    <a href={`${homeHref}#orchardcraft`}>Materials</a>
    <a href={`${homeHref}#journal`}>Journal</a>
    <a href={`${homeHref}#about`}>About</a>
  </nav>
</header>

<main>
  <!-- ══ DESKTOP PDP ══ -->
  <section class="pdp">
    <!-- LEFT: thumbnails -->
    <aside class="pdp__thumbs" id="thumbStrip">
      {images.map((img, i) => (
        <button class={`thumb${i === 0 ? ' is-active' : ''}`} data-gidx={i} aria-label={`View image ${i + 1}`}>
          <img src={img.thumb} alt={img.alt} loading="lazy" />
        </button>
      ))}
    </aside>

    <!-- CENTER: image stack -->
    <div class="pdp__images" id="mainGallery">
      {images.map((img, i) => (
        <div class="gimg" data-gidx={i}>
          <img src={img.full} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>

    <!-- RIGHT: sticky info -->
    <div class="pdp__info">
      <div class="bc"><a href={shopHref}>Shop</a><span class="sep">/</span>Bags</div>
      <h1 class="info-name">{product.title}</h1>
      <p class="info-price" id="infoPrice">{startPrice}</p>
      <div class="info-desc" set:html={product.descriptionHtml || product.description}></div>

      {colorOption && (
        <div class="sw-group">
          <p class="sw-label">{colorOption.name} — <em id="swatchName">{colorOption.values[0]}</em></p>
          <div class="sw-row" id="deskSwatches">
            {colorOption.values.map((v, i) => (
              <button class={`swatch${i === 0 ? ' is-active' : ''}`} style={`--c:${hexFor(v)}`} data-name={v} aria-label={v}></button>
            ))}
          </div>
        </div>
      )}

      {sizeOption && (
        <>
          <p class="size-label">{sizeOption.name}:</p>
          <div class="size-row" id="deskSizes">
            {sizeOption.values.map((v, i) => (
              <button class={`size-btn${i === 0 ? ' is-active' : ''}`} data-name={v}>{v}</button>
            ))}
          </div>
        </>
      )}

      <div class="cta-row">
        <button class="btn-atc btn-buy" id="buyNowBtn">Buy Now</button>
        <div class="btn-atc-wrap">
          <button class="btn-atc btn-add" id="atcBtn">Add to Cart</button>
        </div>
      </div>

      <p class="trust">Free Shipping &nbsp;·&nbsp; 1-Year Warranty &nbsp;·&nbsp; Easy Returns</p>

      <div>
        <div class="acc-item">
          <button class="acc-btn">Shipping &amp; Returns <span class="acc-icon">+</span></button>
          <div class="acc-body"><div class="acc-inner">
            <ul>
              <li>Free shipping across India on all orders</li>
              <li>International shipping calculated at checkout</li>
              <li>Returns within 14 days of delivery, in original condition</li>
            </ul>
          </div></div>
        </div>
        <div class="acc-item">
          <button class="acc-btn">1-Year Warranty <span class="acc-icon">+</span></button>
          <div class="acc-body"><div class="acc-inner">
            Every Mir Kash bag is covered against manufacturing defects for one year from purchase.
          </div></div>
        </div>
        <div class="acc-item">
          <button class="acc-btn">Orchardcraft™ Apple Leather <span class="acc-icon">+</span></button>
          <div class="acc-body"><div class="acc-inner">
            Derived from the peel and core of apples from the food industry in South Tyrol, Italy — no animal hides, and it grows more beautiful with age.
          </div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ MOBILE GALLERY ══ -->
  <div class="mob-gal" id="mobGal">
    <div class="mob-gal__track" id="mobTrack">
      {images.map((img) => (
        <div class="mob-gal__slide"><img src={img.full} alt={img.alt} /></div>
      ))}
    </div>
    <span class="mob-ctr" id="mobCtr">1 / {images.length}</span>
  </div>

  <!-- ══ MOBILE INFO ══ -->
  <div class="mob-info">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:6px">
      <h1 class="info-name" style="margin:0;font-size:clamp(1.5rem,5vw,1.85rem)">{product.title}</h1>
      <p id="mobPrice" style="font-size:15px;font-weight:500;flex-shrink:0;margin-left:12px">{startPrice}</p>
    </div>
    <div class="bc" style="margin-bottom:14px"><a href={shopHref}>Shop</a><span class="sep">/</span>Bags</div>
    <div class="info-desc" style="border:none;padding:0;margin-bottom:20px" set:html={product.description}></div>

    {colorOption && (
      <div class="sw-group">
        <p class="sw-label">{colorOption.name} — <em id="mobSwatchName">{colorOption.values[0]}</em></p>
        <div class="sw-row" id="mobSwatches">
          {colorOption.values.map((v, i) => (
            <button class={`swatch${i === 0 ? ' is-active' : ''}`} style={`--c:${hexFor(v)}`} data-name={v} aria-label={v}></button>
          ))}
        </div>
      </div>
    )}

    {sizeOption && (
      <>
        <p class="size-label" style="margin-top:4px">{sizeOption.name}:</p>
        <div class="size-row" id="mobSizes">
          {sizeOption.values.map((v, i) => (
            <button class={`size-btn${i === 0 ? ' is-active' : ''}`} data-name={v}>{v}</button>
          ))}
        </div>
      </>
    )}
  </div>

  <!-- ══ FEATURES ══ -->
  <section class="features reveal">
    <div class="feat-grid">
      <div class="feat">
        <p class="feat__eye">Craft</p>
        <h3 class="feat__title">Handmade in Jaipur</h3>
        <p class="feat__body">Every Carry-All is stitched by hand at our Jaipur atelier — no shortcuts, no compromises. Artisans cut, stitch, and finish each piece one at a time, with the same care on the first bag as the ten-thousandth.</p>
      </div>
      <div class="feat">
        <p class="feat__eye">Material</p>
        <h3 class="feat__title">Apple Leather</h3>
        <p class="feat__body">Our Orchardcraft™ apple leather is derived from the peel and core of apples leftover from the food industry in South Tyrol. It carries a natural grain and requires no animal hides — and only grows more beautiful with time.</p>
      </div>
      <div class="feat">
        <p class="feat__eye">Ethics</p>
        <h3 class="feat__title">Cruelty-Free Always</h3>
        <p class="feat__body">Every material, every stitch, every finish is entirely animal-free. Not as a trend — but as a founding commitment. Mir Kash will never use animal leather or exotic skins, ever.</p>
      </div>
    </div>
  </section>

  <!-- ══ FEATURE STORY SLIDESHOW ══ -->
  <section class="story">
    <div class="story__left">
      <div class="story__slides">

        <div class="s-slide is-active">
          <p class="s-slide__eye">Inside</p>
          <h3 class="s-slide__title">Organized at its heart</h3>
          <p class="s-slide__body">The double-zip system opens fully flat to reveal a structured interior: suede-lined main compartment, a flat slip pocket, and a magnetic key fob — everything where you expect it.</p>
        </div>

        <div class="s-slide">
          <p class="s-slide__eye">Structure</p>
          <h3 class="s-slide__title">A silhouette that holds</h3>
          <p class="s-slide__body">A semi-rigid base keeps the bag upright and the silhouette crisp, even after a full day of use. The Carry-All never sags, never collapses — it arrives looking exactly as you left it.</p>
        </div>

        <div class="s-slide">
          <p class="s-slide__eye">Hardware</p>
          <h3 class="s-slide__title">Gold that doesn't fade</h3>
          <p class="s-slide__body">All metal components — zippers, rings, and base feet — are 14k gold-plated brass. Solid enough to last a decade. Beautiful enough to notice from across a room.</p>
        </div>

        <div class="s-slide">
          <p class="s-slide__eye">Carry</p>
          <h3 class="s-slide__title">Made for your hand</h3>
          <p class="s-slide__body">The top handle is padded and shaped to sit comfortably in a relaxed grip. Compact enough to tuck under an arm. Structured enough to set on a table and stay standing.</p>
        </div>

      </div>

      <div class="story__foot">
        <div class="prog-bars" id="progBars">
          <div class="prog-bar active"></div>
          <div class="prog-bar"></div>
          <div class="prog-bar"></div>
          <div class="prog-bar"></div>
        </div>
        <div class="story-nav">
          <button class="story-nav__btn" id="storyPrev" aria-label="Previous">‹</button>
          <span class="story-nav__ctr" id="storyCtr">1 / 4</span>
          <button class="story-nav__btn" id="storyNext" aria-label="Next">›</button>
          <button class="story-nav__pause" id="storyPause" aria-label="Pause">⏸</button>
        </div>
      </div>
    </div>

    <div class="story__right">
      <img class="story__img" id="storyImg" src={storyImgArr[0]} alt={product.title} />
    </div>
  </section>

  <!-- ══ FULL-BLEED ══ -->
  <div class="full-bleed reveal">
    <img src={fullBleedImg} alt={product.title} />
  </div>

  <!-- ══ LOOKBOOK ══ -->
  <section class="lookbook reveal">
    <div class="look-grid">
      <div class="look-img"><img src={lookImgs[0]} alt="Lookbook 1" /></div>
      <div class="look-img"><img src={lookImgs[1]} alt="Lookbook 2" /></div>
      <div class="look-img"><img src={lookImgs[2]} alt="Lookbook 3" /></div>
    </div>
    <div class="look-dots">
      <button class="look-dot is-active" aria-label="Set 1"></button>
      <button class="look-dot" aria-label="Set 2"></button>
      <button class="look-dot" aria-label="Set 3"></button>
    </div>
    <p class="look-caption">
      From quiet mornings to late evenings — the Carry-All moves through your day without compromise. Dressed up or down, it always arrives looking right.
    </p>
  </section>
</main>

<!-- ══ STICKY MOBILE BAR ══ -->
<div class="mob-bar">
  <button class="mob-bar__atc mob-bar__add" id="mobAtcBtn">Add to Cart</button>
  <button class="mob-bar__atc mob-bar__buy" id="mobBuyBtn">Buy Now</button>
</div>

<SiteFooter />

<script type="application/json" id="pdpData" set:html={JSON.stringify(clientData)}></script>
<script define:vars={{ firstVariantId, store: market, countryCode: marketConfig.countryCode, cartHref, storyImgs: storyImgArr }}>
  const data = JSON.parse(document.getElementById('pdpData').textContent || '{}');
  const variants = data.variants || [];
  const colorName = data.colorName;
  const sizeName = data.sizeName;

  const state = { color: null, size: null, variantId: firstVariantId };

  function resolveVariant() {
    const match = variants.find((v) => {
      if (colorName && state.color && v.options[colorName] !== state.color) return false;
      if (sizeName && state.size && v.options[sizeName] !== state.size) return false;
      return true;
    }) || variants[0];
    if (!match) return;
    state.variantId = match.id;
    document.querySelectorAll('#infoPrice, #mobPrice').forEach((el) => { el.textContent = match.price; });
    document.querySelectorAll('#atcBtn, #mobAtcBtn').forEach((btn) => {
      btn.disabled = !match.available;
      btn.textContent = match.available ? 'Add to Cart' : 'Sold Out';
      btn.dataset.label = btn.textContent;
    });
    document.querySelectorAll('#buyNowBtn, #mobBuyBtn').forEach((btn) => {
      btn.disabled = !match.available;
      btn.textContent = match.available ? 'Buy Now' : 'Sold Out';
      btn.dataset.label = btn.textContent;
    });
  }

  // Swatches (desktop + mobile kept in sync)
  function wireSwatches(rowId, labelId) {
    const row = document.getElementById(rowId);
    if (!row) return;
    row.querySelectorAll('.swatch').forEach((btn) => {
      btn.addEventListener('click', () => {
        state.color = btn.dataset.name;
        document.querySelectorAll('#deskSwatches .swatch, #mobSwatches .swatch').forEach((b) => {
          b.classList.toggle('is-active', b.dataset.name === state.color);
        });
        document.querySelectorAll('#swatchName, #mobSwatchName').forEach((el) => { el.textContent = state.color; });
        resolveVariant();
      });
    });
  }
  wireSwatches('deskSwatches');
  wireSwatches('mobSwatches');

  function wireSizes(rowId) {
    const row = document.getElementById(rowId);
    if (!row) return;
    row.querySelectorAll('.size-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        state.size = btn.dataset.name;
        document.querySelectorAll('#deskSizes .size-btn, #mobSizes .size-btn').forEach((b) => {
          b.classList.toggle('is-active', b.dataset.name === state.size);
        });
        resolveVariant();
      });
    });
  }
  wireSizes('deskSizes');
  wireSizes('mobSizes');

  // initialise defaults from first active buttons
  state.color = document.querySelector('#deskSwatches .swatch.is-active, #mobSwatches .swatch.is-active')?.dataset.name ?? null;
  state.size = document.querySelector('#deskSizes .size-btn.is-active, #mobSizes .size-btn.is-active')?.dataset.name ?? null;
  resolveVariant();

  // Add to bag — checkout:true => Buy Now (go to Shopify checkout); false => stay on page
  async function addItem(btn) {
    if (!state.variantId || btn.disabled) return;
    const original = btn.dataset.label || btn.textContent;
    btn.dataset.label = original;
    btn.disabled = true;
    btn.textContent = 'Adding…';
    try {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ merchandiseId: state.variantId, quantity: 1, store, countryCode }),
      });
      if (!res.ok) throw new Error('add failed');
      const cart = await res.json();
      document.querySelectorAll('.bag-count').forEach((el) => { el.textContent = String(cart.totalQuantity ?? 0); });
      btn.textContent = 'Added ✓';
      btn.classList.add('is-added');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('is-added');
        btn.disabled = false;
      }, 1600);
    } catch {
      btn.disabled = false; btn.textContent = original;
      alert('Sorry — something went wrong. Please try again.');
    }
  }

  // Buy Now — Amazon-style: checks out ONLY this product via a separate single-item
  // cart, leaving the main cart untouched. India → our /checkout; Global → Shopify.
  async function buyNow(btn) {
    if (!state.variantId || btn.disabled) return;
    const original = btn.dataset.label || btn.textContent;
    btn.dataset.label = original;
    btn.disabled = true;
    btn.textContent = 'Processing…';
    try {
      const res = await fetch('/api/checkout/buynow', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ merchandiseId: state.variantId, quantity: 1, store, countryCode }),
      });
      if (!res.ok) throw new Error('buynow failed');
      const { next } = await res.json();
      if (!next) throw new Error('no next url');
      window.location.href = next;
    } catch {
      btn.disabled = false; btn.textContent = original;
      alert('Sorry — something went wrong. Please try again.');
    }
  }

  document.getElementById('atcBtn')?.addEventListener('click', (e) => addItem(e.currentTarget));
  document.getElementById('mobAtcBtn')?.addEventListener('click', (e) => addItem(e.currentTarget));
  document.getElementById('buyNowBtn')?.addEventListener('click', (e) => buyNow(e.currentTarget));
  document.getElementById('mobBuyBtn')?.addEventListener('click', (e) => buyNow(e.currentTarget));

  // Thumbnails → scroll to gallery image
  document.querySelectorAll('#thumbStrip .thumb').forEach((t) => {
    t.addEventListener('click', () => {
      document.querySelectorAll('#thumbStrip .thumb').forEach((x) => x.classList.remove('is-active'));
      t.classList.add('is-active');
      const target = document.querySelector(`.gimg[data-gidx="${t.dataset.gidx}"]`);
      target?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // Mobile gallery counter
  const mobTrack = document.getElementById('mobTrack');
  const mobCtr = document.getElementById('mobCtr');
  if (mobTrack && mobCtr) {
    const total = mobTrack.children.length;
    mobTrack.addEventListener('scroll', () => {
      const idx = Math.round(mobTrack.scrollLeft / mobTrack.clientWidth) + 1;
      mobCtr.textContent = `${idx} / ${total}`;
    }, { passive: true });
  }

  // Accordions
  document.querySelectorAll('.acc-item .acc-btn').forEach((btn) => {
    btn.addEventListener('click', () => btn.closest('.acc-item').classList.toggle('is-open'));
  });

  // ── Feature story slideshow (auto-advancing, with prev/next/pause) ──
  (function () {
    const sSlides = document.querySelectorAll('.s-slide');
    if (!sSlides.length) return;
    const progBarEls = document.querySelectorAll('.prog-bar');
    const storyImg = document.getElementById('storyImg');
    const storyCtr = document.getElementById('storyCtr');
    let sIdx = 0, sTimer = null, sPaused = false;

    function goStory(n) {
      sIdx = (n + sSlides.length) % sSlides.length;
      sSlides.forEach((s) => s.classList.remove('is-active'));
      sSlides[sIdx].classList.add('is-active');
      progBarEls.forEach((b, i) => {
        b.classList.remove('active', 'done');
        if (i < sIdx) b.classList.add('done');
        if (i === sIdx) b.classList.add('active');
      });
      if (storyImg && storyImgs[sIdx]) {
        storyImg.style.opacity = '0';
        setTimeout(() => { storyImg.src = storyImgs[sIdx]; storyImg.style.opacity = '1'; }, 240);
      }
      if (storyCtr) storyCtr.textContent = (sIdx + 1) + ' / ' + sSlides.length;
    }
    function startTimer() {
      clearInterval(sTimer);
      if (!sPaused) sTimer = setInterval(() => goStory(sIdx + 1), 4200);
    }
    document.getElementById('storyNext')?.addEventListener('click', () => { goStory(sIdx + 1); startTimer(); });
    document.getElementById('storyPrev')?.addEventListener('click', () => { goStory(sIdx - 1); startTimer(); });
    document.getElementById('storyPause')?.addEventListener('click', function () {
      sPaused = !sPaused;
      this.textContent = sPaused ? '▶' : '⏸';
      startTimer();
    });
    startTimer();
  })();

  // ── Lookbook dots (decorative) ──
  document.querySelectorAll('.look-dot').forEach((dot) => {
    dot.addEventListener('click', () => {
      document.querySelectorAll('.look-dot').forEach((d) => d.classList.remove('is-active'));
      dot.classList.add('is-active');
    });
  });

  // ── Scroll reveal (features · full-bleed · lookbook) ──
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('in'); revealObs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach((el) => revealObs.observe(el));

  // Keep the header bag badge in sync with the live cart (also on bfcache back-nav)
  (function () {
    const els = document.querySelectorAll('.bag-count');
    if (!els.length) return;
    async function refresh() {
      try {
        const res = await fetch('/api/cart?store=' + store, { cache: 'no-store' });
        if (!res.ok) return;
        const cart = await res.json();
        els.forEach((el) => { el.textContent = String(cart.totalQuantity ?? 0); });
      } catch {}
    }
    refresh();
    window.addEventListener('pageshow', refresh);
    document.addEventListener('visibilitychange', () => { if (!document.hidden) refresh(); });
  })();

</script>

