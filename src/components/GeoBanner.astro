---
import { MARKETS, MARKET_COOKIE_MAX_AGE, getAlternateUrl } from '~/lib/markets';
import { GEO_SUGGESTION_COOKIE, GEO_DISMISSED_COOKIE } from '~/middleware';
import type { Market } from '~/types/market';

const raw = Astro.cookies.get(GEO_SUGGESTION_COOKIE)?.value;
const suggestion: Market | null =
  raw === 'global' || raw === 'india' ? (raw as Market) : null;

if (!suggestion) {
  // No banner needed for this request.
}

const targetCfg = suggestion ? MARKETS[suggestion] : null;
const switchHref = suggestion ? getAlternateUrl(Astro.url.pathname, suggestion) : '#';
---
{suggestion && targetCfg && (
  <div class="geo-banner" role="region" aria-label="Region suggestion">
    <p class="geo-banner__msg">
      Visiting from <strong>{targetCfg.countryName}</strong>? Switch to <strong>{targetCfg.label}</strong> for local pricing.
    </p>
    <div class="geo-banner__actions">
      <a class="geo-banner__btn geo-banner__btn--primary" href={switchHref} data-geo-switch={suggestion}>Switch</a>
      <button class="geo-banner__btn geo-banner__btn--ghost" type="button" data-geo-dismiss>Stay</button>
    </div>
  </div>
)}

<style>
  .geo-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 400;
    background: #2C1A0E;
    color: #F5F0E8;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 10px 20px;
    font-size: 12px;
    letter-spacing: 0.04em;
    font-family: 'Jost', -apple-system, 'Helvetica Neue', sans-serif;
    box-shadow: 0 2px 12px rgba(0,0,0,.18);
  }
  .geo-banner__msg { margin: 0; line-height: 1.4; }
  .geo-banner__msg strong { font-weight: 600; }
  .geo-banner__actions { display: inline-flex; gap: 10px; }
  .geo-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 14px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    border-radius: 0;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    transition: background .2s, color .2s, border-color .2s;
    font-family: inherit;
  }
  .geo-banner__btn--primary {
    background: #8B1A1A;
    color: #fff;
  }
  .geo-banner__btn--primary:hover { background: #a02020; }
  .geo-banner__btn--ghost {
    background: transparent;
    color: #F5F0E8;
    border-color: rgba(245, 240, 232, .4);
  }
  .geo-banner__btn--ghost:hover { border-color: #F5F0E8; }
  @media (max-width: 600px) {
    .geo-banner {
      flex-direction: column;
      gap: 8px;
      padding: 10px 16px;
      font-size: 11px;
    }
  }
</style>

<script define:vars={{ maxAge: MARKET_COOKIE_MAX_AGE }}>
  const banner = document.querySelector('.geo-banner');
  if (banner) {
    const switchBtn = banner.querySelector('[data-geo-switch]');
    const dismissBtn = banner.querySelector('[data-geo-dismiss]');

    if (switchBtn) {
      switchBtn.addEventListener('click', () => {
        const m = switchBtn.getAttribute('data-geo-switch');
        if (m) {
          document.cookie = `mirkash-market=${m}; path=/; max-age=${maxAge}; samesite=lax`;
        }
        document.cookie = `mirkash-geo-suggestion=; path=/; max-age=0; samesite=lax`;
      });
    }

    if (dismissBtn) {
      dismissBtn.addEventListener('click', () => {
        document.cookie = `mirkash-geo-dismissed=1; path=/; max-age=${maxAge}; samesite=lax`;
        document.cookie = `mirkash-geo-suggestion=; path=/; max-age=0; samesite=lax`;
        banner.remove();
        document.body.style.setProperty('--geo-banner-h', '0px');
      });
    }
  }
</script>
