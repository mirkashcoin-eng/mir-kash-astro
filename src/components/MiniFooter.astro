// Minimal, self-contained footer for the focused sheet pages (cart, checkout).
---
<footer class="mk-foot">
  <nav class="mk-foot__nav">
    <a href="/shop">Shop</a>
    <a href="/#orchardcraft">Materials</a>
    <a href="/#journal">Journal</a>
    <a href="/account">Account</a>
  </nav>
  <p class="mk-foot__copy">© MIR KASH 2026 · Made slowly. Worn forever. Hurts nothing.</p>
