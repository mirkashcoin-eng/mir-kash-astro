<style>
  .mk-foot { max-width: 460px; margin: 0 auto; padding: 30px 22px 44px; border-top: 1px solid #e6e6e6; text-align: center; }
  .mk-foot__nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px 22px; margin-bottom: 14px; }
  .mk-foot__nav a { font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase; color: #6b6b6b; transition: color .2s; text-decoration: none; }
  .mk-foot__nav a:hover { color: #8B1A1A; }
  .mk-foot__copy { font-size: 11px; color: #a3a3a3; font-family: 'Jost', -apple-system, sans-serif; }
</style>
