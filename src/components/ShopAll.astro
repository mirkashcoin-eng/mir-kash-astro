---
import BrandTicker from './BrandTicker.astro';
import SiteHeader from './SiteHeader.astro';
import NavDrawer from './NavDrawer.astro';
import SiteFooter from './SiteFooter.astro';
import { getAllProducts } from '~/lib/shopify/queries';
import { shopifyImage } from '~/lib/shopifyImage';
import { formatMoney } from '~/lib/markets';

const { market, marketConfig } = Astro.locals;
const homeHref = marketConfig.urlPrefix || '/';

const products = await getAllProducts(market, 48);

function normalizeCat(productType: string, tags: string[]): string {
  const haystack = (productType + ' ' + tags.join(' ')).toLowerCase();
  if (/cross\s*body|crossbody/.test(haystack)) return 'crossbody-bags';
  if (/shoulder/.test(haystack))                return 'shoulder-bags';
  if (/duffel|duffle/.test(haystack))           return 'duffel-bags';
  if (/clutch/.test(haystack))                  return 'clutches';
  if (/tote/.test(haystack))                    return 'tote-bags';
  if (/mini/.test(haystack))                    return 'mini-bags';
  if (/hand\s*bag|handbag|bag/.test(haystack))  return 'handbags';
  return 'handbags';
}

const lightProducts = products.map((p) => ({
  handle: p.handle,
  name: p.title.toUpperCase(),
  price: formatMoney(p.priceRange.minVariantPrice, marketConfig.locale),
  cat: normalizeCat(p.productType || '', p.tags),
  material: p.tags.find((t) => /leather|cactus|apple|rattan/i.test(t)) ?? '',
  badge: p.tags.includes('best-seller')
    ? 'Best Seller'
    : p.tags.includes('new')
    ? 'New'
    : p.tags.includes('selling-fast')
    ? 'Selling Fast'
    : null,
  image: p.featuredImage ? shopifyImage(p.featuredImage.url, 600) : null,
  imageAlt: p.featuredImage?.altText ?? p.title,
  hoverImage: (() => {
    const node =
      p.images?.edges?.find((e) => e.node.url !== p.featuredImage?.url)?.node ??
      p.images?.edges?.[1]?.node ??
      null;
    return node ? shopifyImage(node.url, 600) : null;
  })(),
}));
---
<BrandTicker />
<SiteHeader />
<NavDrawer />

<main>

  <nav class="shop-crumb" aria-label="Breadcrumb">
    <p class="shop-crumb__inner">
      <a href={homeHref}>Home</a><span class="sep">/</span>Shop All
    </p>
  </nav>

  <section class="cat-row" aria-label="Shop by category">
    <div class="cat-row__grid">
      {[
        { cat: 'crossbody-bags', num: 'i.',   label: 'Crossbody' },
        { cat: 'handbags',       num: 'ii.',  label: 'Handbag' },
        { cat: 'shoulder-bags',  num: 'iii.', label: 'Shoulder' },
        { cat: 'mini-bags',      num: 'iv.',  label: 'Mini' },
        { cat: 'clutches',       num: 'v.',   label: 'Clutch' },
        { cat: 'duffel-bags',    num: 'vi.',  label: 'Duffel' },
        { cat: 'tote-bags',      num: 'vii.', label: 'Tote' },
      ].map((c) => (
        <button class="cat-tile" data-cat={c.cat} type="button">
          <div class="cat-tile__img" style="background:linear-gradient(170deg,#f0ede8 0%,#e0ddd8 100%);">
            <span class="cat-tile__num" style="color:rgba(20,20,20,.45);">{c.num}</span>
          </div>
          <span class="cat-tile__label">{c.label}</span>
        </button>
      ))}
    </div>
  </section>

  <section class="shop-grid" id="shopGrid"></section>
  <div class="grid-sentinel" id="gridSentinel" aria-hidden="true"></div>

</main>

<SiteFooter />

<script define:vars={{ PRODUCTS: lightProducts, marketPrefix: marketConfig.urlPrefix }}>
  const grid = document.getElementById('shopGrid');

  // Favorites (heart) — persisted in localStorage by product handle
  const FAV_KEY = 'mk_favorites';
  const getFavs = () => { try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; } };
  let favToastTimer;
  function favToast(msg) {
    let t = document.getElementById('favToast');
    if (!t) { t = document.createElement('div'); t.id = 'favToast'; t.className = 'fav-toast'; document.body.appendChild(t); }
    t.textContent = msg;
    t.classList.add('is-shown');
    clearTimeout(favToastTimer);
    favToastTimer = setTimeout(() => t.classList.remove('is-shown'), 1800);
  }
  function toggleFav(handle) {
    const favs = getFavs();
    const i = favs.indexOf(handle);
    const added = i < 0;
    if (added) favs.push(handle); else favs.splice(i, 1);
    localStorage.setItem(FAV_KEY, JSON.stringify(favs));
    return added;
  }

  function renderCard(p) {
    const card = document.createElement('a');
    card.className = 'shop-card';
    card.dataset.cat = p.cat;
    card.href = `${marketPrefix}/products/${p.handle}`;

    const badgeCls = p.badge === 'New' ? 'shop-card__badge--new' : '';
    const badgeHtml = p.badge
      ? `<span class="shop-card__badge ${badgeCls}">${p.badge}</span>`
      : '';

    const placeholderPrimary = 'linear-gradient(170deg,#f0ede8 0%,#e0ddd8 100%)';
    const placeholderAlt     = 'linear-gradient(170deg,#e0ddd8 0%,#d2cec5 100%)';

    const primaryStyle = p.image
      ? `background:url('${p.image}') center/cover no-repeat, ${placeholderPrimary};`
      : `background:${placeholderPrimary};`;
    const altStyle = p.hoverImage
      ? `background:url('${p.hoverImage}') center/cover no-repeat, ${placeholderAlt};`
      : `background:${placeholderAlt};`;
    const placeholderText = p.image ? '' : `<span class="shop-card__placeholder-mono">${p.name.toLowerCase()}</span>`;

    card.innerHTML = `
      <div class="shop-card__img-wrap">
        <div class="shop-card__img shop-card__img--primary" style="${primaryStyle}">
          ${placeholderText}
        </div>
        <div class="shop-card__img shop-card__img--alt" style="${altStyle}"></div>
        ${badgeHtml}
        <button class="shop-card__wish" data-handle="${p.handle}" aria-label="Save ${p.name}" type="button">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </button>
        <button class="shop-card__quick-add" aria-label="Add ${p.name} to bag" type="button">Add to bag</button>
      </div>
      <div class="shop-card__meta">
        <p class="shop-card__name">${p.name}</p>
        <p class="shop-card__price">${p.price}</p>
      </div>
    `;

    const wish = card.querySelector('.shop-card__wish');
    if (getFavs().includes(p.handle)) wish.classList.add('is-saved');
    wish.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const added = toggleFav(p.handle);
      wish.classList.toggle('is-saved', added);
      favToast(added ? 'Added to favorites' : 'Removed from favorites');
    });

    const qa = card.querySelector('.shop-card__quick-add');
    qa.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (qa.classList.contains('is-added')) return;
      const original = qa.textContent;
      qa.classList.add('is-added');
      qa.textContent = 'Added ✓';
      setTimeout(() => {
        qa.textContent = original;
        qa.classList.remove('is-added');
      }, 1400);
    });

    return card;
  }

  const CATALOG = PRODUCTS.slice();
  const BATCH = 8;
  let renderIndex = 0;
  let currentFilter = 'all';
  let storyInserted = false;

  function getFiltered() {
    return currentFilter === 'all'
      ? CATALOG.slice()
      : CATALOG.filter(p => p.cat === currentFilter);
  }

  function insertStoryRow() {
    const story = document.createElement('div');
    story.className = 'shop-story';
    story.setAttribute('aria-label', 'The Orchardcraft story');
    story.innerHTML = `
      <div class="shop-story__img" aria-hidden="true"></div>
      <div class="shop-story__inner">
        <span class="shop-story__eyebrow">Orchardcraft · The material</span>
        <h2 class="shop-story__h2">She was <em>made</em><br>from apples.</h2>
        <p class="shop-story__body">
          Apple pomace — the skin and pulp left from South Tyrol's juice harvest — pressed, dried, and laid flat. The softness of calf leather. The carbon footprint of recovered waste. Hurts nothing.
        </p>
        <a href="#" class="shop-story__link">
          What she's made of
          <svg width="14" height="10" viewBox="0 0 24 12" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="0" y1="6" x2="22" y2="6"/><polyline points="16 1 22 6 16 11"/></svg>
        </a>
      </div>
    `;
    grid.appendChild(story);
  }

  function renderBatch() {
    const items = getFiltered();
    const end = Math.min(renderIndex + BATCH, items.length);
    for (let i = renderIndex; i < end; i++) {
      grid.appendChild(renderCard(items[i]));
    }
    renderIndex = end;
    if (!storyInserted && renderIndex >= 8 && currentFilter === 'all') {
      insertStoryRow();
      storyInserted = true;
    }
  }

  function resetGrid() {
    grid.innerHTML = '';
    renderIndex = 0;
    storyInserted = false;
    renderBatch();
  }

  function setActiveCategory(cat) {
    currentFilter = cat;
    resetGrid();
  }

  document.querySelectorAll('.cat-tile').forEach(tile => {
    tile.addEventListener('click', () => {
      setActiveCategory(tile.dataset.cat);
      const offset = document.getElementById('shopGrid').getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top: offset, behavior: 'smooth' });
    });
  });

  resetGrid();

  const sentinel = document.getElementById('gridSentinel');
  if (sentinel) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && renderIndex < getFiltered().length) {
          renderBatch();
        }
      });
    }, { rootMargin: '600px 0px' });
    io.observe(sentinel);
  }
</script>

<style is:global>
  /* ══════════════════════════════════════
     SHOP V2 — brand-aligned redesign
     Cherry-red signature · serif/sans pair · Orchardcraft story
     ══════════════════════════════════════ */

  :root {
    --serif:        'Cormorant Garamond', 'Times New Roman', serif;
    --cherry:       #8B1A1A;
    --plum:         #5C2D3E;
    --earth:        #C8895A;
    --tan:          #D4B896;
    --depth:        #2C1A0E;

    --paper:        #F5F0E8;
    --white:        #F5F0E8;
  }

  body { background: var(--paper); }

  :root { --ticker-h: 32px; }
  body { padding-top: var(--ticker-h); }
  .page-header.hdr--solid { top: var(--ticker-h); }

  :root { --hdr-h: 64px; }

  .site-header--minimal { border-bottom: 1px solid var(--rule); }
  .site-header--minimal .hdr-wrap {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: var(--hdr-h);
    padding: 0 var(--gutter);
    gap: 24px;
  }
  .site-header--minimal .hdr-right {
    display: flex;
    justify-self: end;
    grid-column: 3;
    align-items: center;
    gap: 14px;
  }
  .site-header--minimal .logo {
    justify-self: center;
    grid-column: 2;
  }
  .site-header--minimal .logo img { height: 22px; }

  .hdr-menu-btn {
    display: none; /* desktop: tabs row replaces the hamburger; shown on mobile */
    align-items: center;
    gap: 12px;
    justify-self: start;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 0;
    color: var(--depth);
    font-family: inherit;
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    font-weight: 500;
  }
  .hdr-menu-btn__bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }
  .hdr-menu-btn__bars span {
    display: block;
    height: 1px;
    width: 100%;
    background: var(--depth);
    transition: transform .25s, opacity .2s;
  }
  .hdr-menu-btn:hover .hdr-menu-btn__bars span:first-child { transform: translateX(-3px); }
  .hdr-menu-btn:hover { color: var(--cherry); }
  .hdr-menu-btn:hover .hdr-menu-btn__bars span { background: var(--cherry); }

  .hdr-icon-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: var(--depth);
    transition: color .2s;
  }
  .hdr-icon-btn:hover { color: var(--cherry); }
  .hdr-bag__count {
    font-family: var(--serif);
    font-style: normal;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0;
    margin-left: 2px;
    line-height: 1;
  }

  .nav-drawer {
    position: fixed;
    inset: 0;
    z-index: 300;
    pointer-events: none;
    visibility: hidden;
  }
  .nav-drawer.is-open {
    pointer-events: auto;
    visibility: visible;
  }
  .nav-drawer__scrim {
    position: absolute;
    inset: 0;
    background: rgba(20, 12, 8, 0);
    border: none;
    cursor: pointer;
    transition: background .35s ease;
  }
  .nav-drawer.is-open .nav-drawer__scrim {
    background: rgba(20, 12, 8, 0.32);
  }
  .nav-drawer__panel {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: min(440px, 90vw);
    background: var(--paper);
    transform: translateX(-100%);
    transition: transform .42s cubic-bezier(.2,.7,.2,1);
    display: flex;
    flex-direction: column;
    padding: clamp(28px, 4vw, 48px) clamp(28px, 4vw, 48px) clamp(28px, 3vw, 40px);
    box-shadow: 0 0 60px rgba(0,0,0,0);
  }
  .nav-drawer.is-open .nav-drawer__panel {
    transform: translateX(0);
    box-shadow: 0 0 60px rgba(0,0,0,0.10);
  }
  .nav-drawer__close {
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--depth);
    font-family: inherit;
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    font-weight: 500;
    padding: 4px 0;
    margin-bottom: clamp(24px, 4vw, 56px);
    transition: color .2s;
  }
  .nav-drawer__close:hover { color: var(--cherry); }

  .nav-drawer__list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-drawer__list li a {
    display: grid;
    grid-template-columns: 28px 1fr;
    column-gap: 16px;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule);
    color: var(--depth);
    transition: color .25s, padding-left .25s;
  }
  .nav-drawer__list li a:hover {
    color: var(--cherry);
    padding-left: 6px;
  }
  .nav-num {
    font-family: var(--serif);
    font-style: normal;
    font-weight: 400;
    font-size: 13px;
    color: var(--ink-mid);
  }
  .nav-word {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(20px, 1.8vw, 26px);
    line-height: 1;
    letter-spacing: 0;
  }
  .nav-word em {
    font-style: normal;
    color: var(--cherry);
  }
  .nav-sub {
    grid-column: 2 / 3;
    font-family: var(--serif);
    font-style: normal;
    font-weight: 300;
    font-size: 14px;
    color: var(--ink-mid);
    margin-top: 4px;
  }

  .nav-drawer__foot {
    margin-top: auto;
    padding-top: clamp(24px, 3vw, 36px);
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .nav-drawer__foot a {
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--depth);
    transition: color .2s;
  }
  .nav-drawer__foot a:hover { color: var(--cherry); }
  .nav-drawer__sig {
    font-family: var(--serif);
    font-style: normal;
    font-weight: 300;
    font-size: 13px;
    color: var(--ink-mid);
    margin-top: 6px;
    letter-spacing: 0;
    text-transform: none;
  }

  @media (max-width: 768px) {
    :root { --hdr-h: 56px; }
    .site-header--minimal .hdr-wrap {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      position: static;
      padding: 0 16px;
      gap: 12px;
    }
    .site-header--minimal .logo {
      position: static;
      transform: none;
      justify-self: center;
    }
    .site-header--minimal .logo img { height: 18px; }
    .hdr-menu-btn__label { display: none; }
    .hdr-menu-btn { display: none; }
    .hdr-icon-btn .hdr-bag__count { font-size: 13px; }
    .site-header--minimal .hdr-right { gap: 8px; }
  }

  .brand-ticker {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--ticker-h);
    background: var(--cherry);
    color: #fff;
    overflow: hidden;
    z-index: 200;
    display: flex;
    align-items: center;
    user-select: none;
  }
  .brand-ticker__track {
    display: flex;
    flex-wrap: nowrap;
    white-space: nowrap;
    animation: tickerScroll 48s linear infinite;
    will-change: transform;
  }
  .brand-ticker:hover .brand-ticker__track { animation-play-state: paused; }
  .brand-ticker__seq {
    display: flex;
    align-items: center;
    gap: 38px;
    padding-right: 38px;
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    font-weight: 500;
    flex-shrink: 0;
  }
  .brand-ticker__seq .tick-dot {
    opacity: .6;
    font-weight: 400;
    font-size: 13px;
    line-height: 1;
    transform: translateY(-1px);
  }
  .brand-ticker__seq em {
    font-style: normal;
    font-weight: 600;
    letter-spacing: var(--tr-caps);
  }
  @keyframes tickerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }


  .page-header.hdr--solid { background: var(--paper); }

  .shop-tag-strip {
    background: var(--paper);
    padding: clamp(28px, 4vw, 56px) var(--gutter) clamp(20px, 2.4vw, 28px);
    text-align: center;
  }
  .shop-tag-strip__line {
    font-family: var(--serif);
    font-weight: 300;
    font-style: normal;
    font-size: clamp(20px, 2.2vw, 30px);
    line-height: 1.25;
    letter-spacing: 0.005em;
    color: var(--depth);
  }
  .shop-tag-strip__line em {
    font-style: normal;
    color: var(--cherry);
    font-weight: 400;
  }

  .shop-crumb {
    background: var(--paper);
    padding: clamp(24px, 3vw, 40px) var(--gutter) 0;
    text-align: left;
  }
  .shop-crumb__inner {
    font-size: 10.5px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    color: var(--ink-mid);
    font-weight: 500;
  }
  .shop-crumb__inner a { color: var(--ink-mid); transition: color .2s; }
  .shop-crumb__inner a:hover { color: var(--cherry); }
  .shop-crumb__inner .sep { margin: 0 8px; opacity: .5; }

  .shop-title {
    background: var(--paper);
    padding: clamp(20px, 2.6vw, 40px) var(--gutter) clamp(36px, 4vw, 56px);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 40px;
    border-bottom: 1px solid var(--rule);
  }
  .shop-title__h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(72px, 11vw, 168px);
    line-height: .9;
    letter-spacing: -0.01em;
    color: var(--depth);
  }
  .shop-title__h1 .amp {
    font-style: normal;
    color: var(--cherry);
    font-weight: 400;
  }
  .shop-title__sub {
    font-family: var(--serif);
    font-style: normal;
    font-weight: 300;
    font-size: clamp(15px, 1.3vw, 19px);
    color: var(--ink-mid);
    margin-top: 14px;
    max-width: 48ch;
    line-height: 1.4;
  }
  .shop-title__count {
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    color: var(--ink-mid);
    font-weight: 500;
    padding-bottom: 18px;
    white-space: nowrap;
  }
  .shop-title__count strong {
    color: var(--ink);
    font-weight: 500;
  }

  .cat-row {
    background: var(--paper);
    padding: clamp(40px, 4.5vw, 64px) var(--gutter) clamp(40px, 4.5vw, 64px);
  }
  .cat-row__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 22px;
    margin-bottom: 26px;
    border-bottom: 1px solid var(--rule);
  }
  .cat-row__title {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(24px, 2.6vw, 36px);
    letter-spacing: 0;
    color: var(--depth);
  }
  .cat-row__title .accent {
    font-style: normal;
    color: var(--cherry);
  }
  .cat-row__hint {
    font-size: 11px;
    letter-spacing: var(--tr-caps);
    text-transform: uppercase;
    color: var(--ink-mid);
    font-weight: 500;
  }
  .cat-row__grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: clamp(8px, 1vw, 14px);
  }
  .cat-tile {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    text-align: left;
    display: block;
    position: relative;
    overflow: visible;
  }
  .cat-tile__img {
    aspect-ratio: 5 / 7;
    width: 100%;
    overflow: hidden;
    position: relative;
    transition: transform .5s cubic-bezier(.2,.7,.2,1);
  }
  .cat-tile:hover .cat-tile__img { transform: translateY(-4px); }
  .cat-tile__num {
    position: absolute;
    top: clamp(10px, 1.2vw, 14px);
    left: clamp(10px, 1.2vw, 14px);
    font-family: var(--serif);
    font-style: normal;
    font-weight: 400;
