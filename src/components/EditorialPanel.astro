---
interface Props {
  image?: string;
  background?: string;
  title: string;
  emphasis: string;
  cta: string;
  href?: string;
}

const { image, background, title, emphasis, cta, href = '#' } = Astro.props;

const style = image
  ? `background-image:url('${image}'); background-size:cover; background-position:center; background-repeat:no-repeat;`
  : background
  ? `background:${background};`
  : '';
---
<div class="ed-panel" style={style}>
  <div class="ed-text">
    <h2>{title} <em>{emphasis}</em></h2>
    <a href={href}>{cta}</a>
  </div>
</div>
