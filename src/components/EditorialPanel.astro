---
interface Props {
  image?: string;
  imageMobile?: string;
  background?: string;
  title?: string;
  emphasis?: string;
  cta?: string;
  href?: string;
}

const { image, imageMobile, background, title, emphasis, cta, href = '#' } = Astro.props;
const heading = emphasis ? `${title} ` : title;

// Desktop/mobile artwork is swapped by a media query in styles.css via --bg-d / --bg-m.
const style = image
  ? `--bg-d:url('${image}'); --bg-m:url('${imageMobile ?? image}');`
  : background
  ? `background:${background};`
  : '';
---
<div class="ed-panel" style={style}>
  {href && href !== '#' && <a class="ed-cover" href={href} aria-label={title ? `Shop ${title}${emphasis ? ' ' + emphasis : ''}` : 'Shop now'}></a>}
  {(title || cta) && (
    <div class="ed-text">
      {title && <h2>{heading}{emphasis && <em>{emphasis}</em>}</h2>}
      {cta && <a href={href}>{cta}</a>}
    </div>
  )}
</div>
