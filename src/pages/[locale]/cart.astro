---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CartPage from '~/components/CartPage.astro';
import { getMarketBySlug } from '~/lib/markets';

const market = getMarketBySlug(Astro.params.locale!);
if (!market || market.isDefault) return new Response(null, { status: 404 });
---
<BaseLayout title="Your Bag — Mir Kash" path="/cart">
  <CartPage />
</BaseLayout>
