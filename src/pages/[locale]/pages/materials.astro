---
import BaseLayout from '~/layouts/BaseLayout.astro';
import MaterialsContent from '~/components/content/MaterialsContent.astro';
import { getMarketBySlug } from '~/lib/markets';

const market = getMarketBySlug(Astro.params.locale!);
if (!market || market.isDefault) return new Response(null, { status: 404 });
---
<BaseLayout title="Materials — Mir Kash" path="/pages/materials" description="The materials behind Mir Kash — apple leather, plant leathers, microfibre, and high-grade synthetic vegan leathers.">
  <MaterialsContent />
</BaseLayout>
