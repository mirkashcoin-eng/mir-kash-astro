---
import BaseLayout from '~/layouts/BaseLayout.astro';
import FaqContent from '~/components/content/FaqContent.astro';
import { getMarketBySlug } from '~/lib/markets';

const market = getMarketBySlug(Astro.params.locale!);
if (!market || market.isDefault) return new Response(null, { status: 404 });
---
<BaseLayout title="FAQ — Mir Kash" path="/pages/faq" description="Mir Kash FAQ — materials, vegan leathers, orders, shipping, returns, warranty, and bag care.">
  <FaqContent />
</BaseLayout>
