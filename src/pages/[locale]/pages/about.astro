---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AboutContent from '~/components/content/AboutContent.astro';
import { getMarketBySlug } from '~/lib/markets';

const market = getMarketBySlug(Astro.params.locale!);
if (!market || market.isDefault) return new Response(null, { status: 404 });
---
<BaseLayout title="About — Mir Kash" path="/pages/about" description="Mir Kash — beautiful vegan bags made from plant-based and synthetic leathers. Our story, our beliefs, and the founder.">
  <AboutContent />
</BaseLayout>
