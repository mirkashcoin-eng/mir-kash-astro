SHOPIFY_GLOBAL_DOMAIN=your-store.myshopify.com
SHOPIFY_GLOBAL_TOKEN=your_storefront_api_public_token
SHOPIFY_IN_DOMAIN=your-store.myshopify.com
SHOPIFY_IN_TOKEN=your_storefront_api_public_token

# ── India custom checkout (India store only) ──────────────────────────────────
# Shopify India Admin API — new Dev Dashboard app (scopes: read/write_orders + read/write_draft_orders)
# Use the store's *.myshopify.com domain here (Admin API does not use the custom domain).
# The server exchanges Client ID + Secret for a short-lived token via the client-credentials grant.
SHOPIFY_IN_ADMIN_DOMAIN=your-india-store.myshopify.com
SHOPIFY_IN_ADMIN_CLIENT_ID=your_app_client_id
SHOPIFY_IN_ADMIN_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Global store Admin API (optional) ─────────────────────────────────────────
# Powers the account section for Global-store customers: order history + returns +
# name/address lookup. Create a Global store Admin app (scopes: read_orders,
# write_orders, read_customers). No-ops until all three are set.
SHOPIFY_GL_ADMIN_DOMAIN=your-global-store.myshopify.com
SHOPIFY_GL_ADMIN_CLIENT_ID=your_app_client_id
SHOPIFY_GL_ADMIN_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cashfree Payment Gateway (server-side only)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox          # sandbox | production

# Cashfree client SDK mode (public/client-safe)
PUBLIC_CASHFREE_MODE=sandbox  # sandbox | production

# Firebase — customer accounts (Google sign-in) + Firestore (saved address + leads)
# Client-safe web config (from Firebase console → Project settings → Web app):
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
# Firebase setup: Auth → enable Google provider + add your domain to Authorized domains;
# create a Firestore database; set rules:
#   match /profiles/{uid}   { allow read, write: if request.auth != null && request.auth.uid == uid; }
#   match /checkout_leads/{d} { allow create: if true; allow read: if false; }
