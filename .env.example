SHOPIFY_GLOBAL_DOMAIN=your-store.myshopify.com
SHOPIFY_GLOBAL_TOKEN=your_storefront_api_public_token
SHOPIFY_IN_DOMAIN=your-store.myshopify.com
SHOPIFY_IN_TOKEN=your_storefront_api_public_token

# ── India custom checkout (India store only) ──────────────────────────────────
# Shopify India Admin API — new Dev Dashboard app (scopes: read/write_orders + read/write_draft_orders)
# Use the store's *.myshopify.com domain here (Admin API does not use the custom domain).
# The server exchanges Client ID + Secret for a short-lived token via the client-credentials grant.
SHOPIFY_IN_ADMIN_DOMAIN=your-india-store.myshopify.com
SHOPIFY_IN_ADMIN_CLIENT_ID=your_app_client_id
SHOPIFY_IN_ADMIN_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cashfree Payment Gateway (server-side only)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox          # sandbox | production

# Cashfree client SDK mode (public/client-safe)
PUBLIC_CASHFREE_MODE=sandbox  # sandbox | production

# Supabase — lead capture (checkout_leads table) + customer accounts
# Server-side (secret):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Client-safe (browser, for Google sign-in):
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Supabase setup: enable Google provider in Auth; create a `profiles` table:
#   create table profiles (id uuid primary key references auth.users on delete cascade,
#     full_name text, phone text, address1 text, address2 text, city text,
#     province text, zip text, email text, updated_at timestamptz default now());
#   alter table profiles enable row level security;
#   create policy "own profile" on profiles for all using (auth.uid() = id) with check (auth.uid() = id);
